---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'STH Design-Katalog',
  description = 'Website-Stilrichtungen für Kundengespräche – STH Digital',
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
