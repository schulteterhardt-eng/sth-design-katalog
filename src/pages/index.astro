---
import BaseLayout from '../layouts/BaseLayout.astro';
import DemoHeader from '../components/DemoHeader.astro';
import DemoFooter from '../components/DemoFooter.astro';
import StyleCard from '../components/StyleCard.astro';

const styles = [
  { title:'Modern & Klar',         description:'Klare Linien, viel Weißraum, technische Präzision. Für Agenturen, Software und Startups.',                    slug:'modern',    palette:['#f8fafc','#e2e8f0','#3b82f6','#0f172a'],  tag:'Technologie · Agentur · SaaS' },
  { title:'Business & Seriös',     description:'Strukturiert, vertrauenswürdig, professionell. Für Kanzleien, Berater und etablierte Unternehmen.',           slug:'business',  palette:['#1e3a5f','#2d5986','#f0f4f8','#c9a23d'],  tag:'Kanzlei · Beratung · B2B' },
  { title:'Handwerk & Bodenständig', description:'Nahbar, ehrlich, authentisch. Für Handwerksbetriebe und lokale Dienstleister.',                             slug:'handwerk',  palette:['#44403c','#78350f','#b45309','#fef3c7'],  tag:'Handwerk · Regional · Lokal' },
  { title:'Medizin & Vertrauen',   description:'Ruhig, klar, vertrauensbildend. Für Praxen, Therapeuten und Pflegeeinrichtungen.',                            slug:'medizin',   palette:['#0e7490','#06b6d4','#f0fdfa','#1e293b'],  tag:'Medizin · Therapie · Pflege' },
  { title:'Editorial & Literatur', description:'Typografie im Vordergrund, ruhige Flächen. Für Verlage, Autoren und Kultureinrichtungen.',                    slug:'editorial', palette:['#1c1917','#a8a29e','#fafaf9','#ca8a04'],  tag:'Kultur · Literatur · Verlag' },
  { title:'Cool & Dynamisch',      description:'Kräftige Kontraste, mutige Typografie. Für Sport, Fitness und moderne Marken mit Ausstrahlung.',             slug:'cool',      palette:['#09090b','#7c3aed','#a78bfa','#22d3ee'],  tag:'Sport · Fitness · Lifestyle' },
  { title:'Abenteuer & Outdoor',   description:'Natur, Weite, Ursprünglichkeit. Für Tourismus, Outdoor-Marken und Freizeitangebote.',                        slug:'abenteuer', palette:['#14532d','#166534','#d97706','#1c1917'],  tag:'Outdoor · Tourismus · Natur' },
  { title:'Kindlich & Verspielt',  description:'Farbenfroh, freundlich, einladend. Für Kitas, Spielzeug und Kinderangebote.',                                 slug:'kindlich',  palette:['#f97316','#22c55e','#3b82f6','#ec4899'],  tag:'Kinder · Bildung · Freizeit' },
  { title:'Premium & Elegant',     description:'Zurückhaltend, hochwertig, exklusiv. Für Luxusmarken, Hotels und Feines.',                                    slug:'premium',   palette:['#0c0a09','#292524','#d4af37','#fafaf9'],  tag:'Luxus · Hotel · Schmuck' },
  { title:'Animiert & Interaktiv', description:'Bewegung als Gestaltungsmittel. Für Kreativagenturen, Apps und digitale Produkte.',                           slug:'animated',  palette:['#1e1b4b','#4f46e5','#a855f7','#ec4899'],  tag:'Digital · App · Kreativ' },
];
---

<BaseLayout title="STH Design-Katalog">
  <div style="min-height:100vh; display:flex; flex-direction:column; background:#f8fafc;">
    <DemoHeader />

    <main style="flex:1; max-width:72rem; margin:0 auto; width:100%; padding:2.5rem 1rem 4rem;">

      <!-- Hero -->
      <div style="text-align:center; padding:3rem 1rem 3.5rem;">
        <p style="font-size:0.75rem; font-weight:700; color:#1a7fa0; text-transform:uppercase; letter-spacing:0.16em; margin:0 0 1rem;">STH Digital · Internes Tool</p>
        <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:800; color:#0f172a; line-height:1.1; letter-spacing:-0.02em; margin:0 0 1rem;">Design-Katalog</h1>
        <p style="font-size:1.0625rem; color:#64748b; max-width:46ch; margin:0 auto; line-height:1.6;">
          10 Stilrichtungen für Kundengespräche – zeigt welche Designsprache zu einem Unternehmen passt.
        </p>
      </div>

      <!-- Grid -->
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.25rem;">
        {styles.map(s => <StyleCard {...s} />)}
      </div>
    </main>

    <DemoFooter />
  </div>
</BaseLayout>
