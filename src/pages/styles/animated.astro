---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
import DemoCTA from '../../components/DemoCTA.astro';
---

<BaseLayout title="Animiert & Interaktiv – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif;">
  <DemoHeader showBack currentStyle="Animiert & Interaktiv" />

  <div style="flex:1; background:#0f0e17;">

    <!-- Nav: Glasmorphism -->
    <nav style="background:rgba(15,14,23,0.8); backdrop-filter:blur(16px); border-bottom:1px solid rgba(255,255,255,0.07); position:sticky; top:42px; z-index:40;">
      <div style="max-width:72rem; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:64px;">
        <span style="font-size:1rem; font-weight:800; background:linear-gradient(90deg,#a855f7,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; letter-spacing:0.02em;">Motion Lab</span>
        <div style="display:flex; align-items:center; gap:2rem;" class="hidden md:flex">
          {['Work','Services','About','Contact'].map(l => (
            <a href="#" style="font-size:0.8125rem; color:rgba(255,255,255,0.45); text-decoration:none; letter-spacing:0.08em; transition:color 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.45)'">{l}</a>
          ))}
          <a href="#" style="background:linear-gradient(135deg,#a855f7,#ec4899); color:white; font-size:0.8125rem; font-weight:700; padding:0.5rem 1.25rem; text-decoration:none; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Start Project</a>
        </div>
        <button style="background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.5);" class="md:hidden" aria-label="Menü">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>

    <!-- Hero: Animierter Gradient-Hintergrund -->
    <section class="anim-shimmer" style="background:linear-gradient(135deg,#1e1b4b,#4c1d95,#831843,#1e1b4b); min-height:90vh; display:flex; align-items:center; padding:5rem 1.5rem; position:relative; overflow:hidden;">
      <!-- Radiale Lichtpunkte -->
      <div class="anim-float" style="position:absolute; top:20%; left:15%; width:300px; height:300px; background:radial-gradient(circle,rgba(168,85,247,0.35),transparent 70%); border-radius:50%; pointer-events:none;" aria-hidden="true"></div>
      <div class="anim-float d2" style="position:absolute; bottom:20%; right:10%; width:250px; height:250px; background:radial-gradient(circle,rgba(236,72,153,0.3),transparent 70%); border-radius:50%; pointer-events:none;" aria-hidden="true"></div>

      <div style="max-width:72rem; margin:0 auto; width:100%; position:relative;">
        <p class="anim-up" style="font-size:0.75rem; font-weight:700; color:#a855f7; letter-spacing:0.2em; text-transform:uppercase; margin:0 0 1.25rem;">Creative Motion Studio</p>
        <h1 class="anim-up d1" style="font-size:clamp(2.5rem,7vw,5rem); font-weight:900; color:white; line-height:1.0; letter-spacing:-0.03em; margin:0 0 1.5rem;">
          Bewegung<br />
          <span style="background:linear-gradient(90deg,#a855f7,#ec4899,#fb923c); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">trifft Design.</span>
        </h1>
        <p class="anim-up d2" style="color:rgba(255,255,255,0.6); font-size:1.0625rem; line-height:1.75; max-width:44ch; margin:0 0 2.5rem;">
          Wir verbinden Animation, Interaktion und Storytelling zu digitalen Erlebnissen, die Menschen berühren – und im Gedächtnis bleiben.
        </p>
        <div class="anim-up d3" style="display:flex; flex-wrap:wrap; gap:1rem;">
          <a href="#" class="anim-glow" style="background:linear-gradient(135deg,#a855f7,#ec4899); color:white; font-size:0.9375rem; font-weight:700; padding:1rem 2rem; text-decoration:none; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Projekt starten</a>
          <a href="#" style="border:1px solid rgba(255,255,255,0.2); color:white; font-size:0.9375rem; font-weight:600; padding:1rem 1.75rem; text-decoration:none; transition:border-color 0.2s,background 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.6)';this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)';this.style.background='transparent'">Showreel ansehen</a>
        </div>
      </div>
    </section>

    <!-- Services: Animated Cards -->
    <section style="background:#0f0e17; padding:5rem 1.5rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <p class="anim-up" style="font-size:0.75rem; font-weight:700; color:#a855f7; letter-spacing:0.2em; text-transform:uppercase; margin:0 0 0.75rem;">What we do</p>
        <h2 class="anim-up d1" style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:900; color:white; margin:0 0 3rem; letter-spacing:-0.02em;">Leistungen mit Seele.</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1.25rem;">
          {[
            { gradient:'linear-gradient(135deg,#4f46e5,#7c3aed)', icon:'✦', title:'Web Animation', text:'CSS- und JS-Animationen, die Nutzererlebnisse lebendig machen.' },
            { gradient:'linear-gradient(135deg,#7c3aed,#ec4899)', icon:'◈', title:'UI Motion Design', text:'Micro-Interactions und State-Transitions für ein flüssiges Interface.' },
            { gradient:'linear-gradient(135deg,#ec4899,#f97316)', icon:'◇', title:'Interactive Storytelling', text:'Scroll-basierte Erlebnisse, die eine Geschichte mit Bewegung erzählen.' },
          ].map((s,i) => (
            <div class={`anim-up d${i+1}`} style={`background:#1a1825; border:1px solid rgba(255,255,255,0.07); padding:2rem; transition:border-color 0.3s,transform 0.3s;`} onmouseover="this.style.borderColor='rgba(168,85,247,0.4)';this.style.transform='translateY(-4px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.07)';this.style.transform='none'">
              <div style={`width:40px; height:40px; background:${s.gradient}; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem; font-size:1.125rem; color:white;`}>{s.icon}</div>
              <h3 style="font-size:1rem; font-weight:800; color:white; margin:0 0 0.625rem;">{s.title}</h3>
              <p style="color:rgba(255,255,255,0.45); font-size:0.9375rem; line-height:1.65; margin:0;">{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DemoCTA headline="Bereit, Ihre Website zum Leben zu erwecken?" body="Zeigen Sie uns Ihre Idee – wir zeigen Ihnen, was möglich ist." buttonText="Jetzt loslegen" bg="linear-gradient(135deg,#4c1d95,#831843)" color="white" buttonBg="linear-gradient(135deg,#a855f7,#ec4899)" buttonColor="white" />

    <div style="background:#0f0e17; padding:1.25rem 1.5rem; border-top:1px solid rgba(255,255,255,0.07);">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.8125rem; color:rgba(255,255,255,0.35); margin:0;"><strong style="color:rgba(255,255,255,0.6);">Geeignet für:</strong> Kreativagenturen, Portfolio-Seiten, SaaS-Produkte, App-Startups, digitale Kampagnen.</p>
      </div>
    </div>
  </div>

  <DemoFooter />
</div>
</BaseLayout>
