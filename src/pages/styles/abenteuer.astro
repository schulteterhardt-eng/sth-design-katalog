---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
import DemoCTA from '../../components/DemoCTA.astro';
---

<BaseLayout title="Abenteuer & Outdoor – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif;">
  <DemoHeader showBack currentStyle="Abenteuer & Outdoor" />

  <div style="flex:1; background:#1c1917;">

    <!-- Hero: Fullscreen Natur-Gradient -->
    <section style="min-height:95vh; position:relative; display:flex; flex-direction:column; overflow:hidden;">
      <!-- Nav (transparent auf Hero) -->
      <nav style="position:absolute; top:0; left:0; right:0; z-index:40; padding:1.25rem 1.5rem;">
        <div style="max-width:72rem; margin:0 auto; display:flex; align-items:center; justify-content:space-between;">
          <div style="display:flex; align-items:center; gap:0.625rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z"/></svg>
            <span style="font-size:1.0625rem; font-weight:800; color:white; letter-spacing:0.02em;">OutdoorBase</span>
          </div>
          <div style="display:flex; align-items:center; gap:2rem;" class="hidden md:flex">
            {['Touren','Ausrüstung','Guides','Community'].map(l => (
              <a href="#" style="font-size:0.875rem; font-weight:600; color:rgba(255,255,255,0.7); text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.7)'">{l}</a>
            ))}
            <a href="#" style="background:#d97706; color:white; font-size:0.8125rem; font-weight:700; padding:0.5625rem 1.25rem; text-decoration:none; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Tour buchen</a>
          </div>
          <button style="background:none; border:none; cursor:pointer; color:white;" class="md:hidden" aria-label="Menü">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </nav>

      <!-- Nature gradient background -->
      <div style="position:absolute; inset:0; background:linear-gradient(180deg,#0c4a6e 0%,#166534 45%,#14532d 70%,#1c1917 100%);" aria-hidden="true"></div>
      <div style="position:absolute; inset:0; background:linear-gradient(180deg,rgba(0,0,0,0.2) 0%,transparent 40%,rgba(0,0,0,0.5) 100%);" aria-hidden="true"></div>

      <!-- Hero Text -->
      <div style="position:relative; flex:1; display:flex; align-items:flex-end; padding:2rem 1.5rem 4rem;">
        <div style="max-width:72rem; margin:0 auto; width:100%;">
          <p style="font-size:0.75rem; font-weight:700; color:#d97706; letter-spacing:0.2em; text-transform:uppercase; margin:0 0 1.25rem;">Nordrhein-Westfalen · Alpen · Weltweit</p>
          <h1 style="font-size:clamp(2.5rem,7vw,5rem); font-weight:900; color:white; line-height:1.0; letter-spacing:-0.02em; margin:0 0 1.5rem;">
            Raus.<br />
            Weiter.<br />
            <span style="color:#d97706;">Unvergesslich.</span>
          </h1>
          <p style="color:rgba(255,255,255,0.7); font-size:1.0625rem; line-height:1.7; max-width:46ch; margin:0 0 2.5rem;">
            Geführte Outdoor-Touren und Abenteuerreisen für alle, die Natur nicht nur anschauen, sondern erleben wollen.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:1rem;">
            <a href="#" style="background:#d97706; color:white; font-size:0.9375rem; font-weight:800; padding:1rem 2rem; text-decoration:none; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Touren entdecken</a>
            <a href="#" style="border:2px solid rgba(255,255,255,0.4); color:white; font-size:0.875rem; font-weight:600; padding:1rem 1.75rem; text-decoration:none; transition:border-color 0.2s;" onmouseover="this.style.borderColor='white'" onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'">Galerie ansehen</a>
          </div>

          <!-- Stats -->
          <div style="display:flex; gap:2.5rem; margin-top:3rem; padding-top:2.5rem; border-top:1px solid rgba(255,255,255,0.15); flex-wrap:wrap;">
            {[['2.500+','Teilnehmer'],['180','Touren'],['12','Länder']].map(([n,l]) => (
              <div>
                <p style="font-size:1.75rem; font-weight:900; color:#d97706; margin:0; line-height:1;">{n}</p>
                <p style="font-size:0.75rem; color:rgba(255,255,255,0.5); margin:0.25rem 0 0; letter-spacing:0.1em; text-transform:uppercase;">{l}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Blocks -->
    <section style="background:#1c1917; padding:5rem 1.5rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:900; color:white; margin:0 0 3rem;">Unsere Angebote</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1.25rem;">
          {[
            { icon:'⛰️', title:'Bergtouren', text:'Von der Halbtageswanderung bis zur anspruchsvollen Alpenüberquerung.' },
            { icon:'🏕️', title:'Zelten & Wildcampen', text:'Mit Guide durch die Wildnis – Ausrüstung, Wissen, Sicherheit inklusive.' },
            { icon:'🚵', title:'Mountainbike', text:'Geführte Trails in NRW, Eifel und den Alpen für alle Levels.' },
          ].map(f => (
            <div style="background:#292524; padding:2rem; border-left:3px solid #d97706; transition:background 0.2s;" onmouseover="this.style.background='#3c3835'" onmouseout="this.style.background='#292524'">
              <span style="font-size:1.75rem; display:block; margin-bottom:1rem;">{f.icon}</span>
              <h3 style="font-size:1rem; font-weight:800; color:white; margin:0 0 0.5rem;">{f.title}</h3>
              <p style="color:rgba(255,255,255,0.55); font-size:0.9375rem; line-height:1.65; margin:0;">{f.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DemoCTA headline="Ihre nächste Expedition wartet." body="Plätze sind begrenzt. Sichern Sie sich jetzt Ihren Platz auf der nächsten Tour." buttonText="Jetzt Tour buchen" bg="linear-gradient(135deg,#166534,#14532d)" color="white" buttonBg="#d97706" buttonColor="white" />

    <div style="background:#1c1917; padding:1.25rem 1.5rem; border-top:1px solid rgba(255,255,255,0.08);">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.8125rem; color:rgba(255,255,255,0.4); margin:0;"><strong style="color:rgba(255,255,255,0.7);">Geeignet für:</strong> Reisebüros, Outdoor-Anbieter, Campingplätze, Sportschulen, Naturparks, Abenteuerveranstalter.</p>
      </div>
    </div>
  </div>

  <DemoFooter />
</div>
</BaseLayout>
