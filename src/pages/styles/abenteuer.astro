---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
---

<BaseLayout title="Abenteuer & Outdoor – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif; background:#0c1408; color:white;">

  <DemoHeader showBack currentStyle="Abenteuer & Outdoor" />

  <!-- Nav: Transparent über dem Hero -->
  <nav style="background:rgba(12,20,8,0.7); backdrop-filter:blur(10px); border-bottom:1px solid rgba(255,255,255,0.07); position:sticky; top:42px; z-index:40;">
    <div style="max-width:80rem; margin:0 auto; padding:0 2rem; height:60px; display:flex; align-items:center; justify-content:space-between;">
      <div style="display:flex; align-items:center; gap:0.625rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#c4a35a" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l6-4 6 4 6-4v14l-6 4-6-4-6 4V7z"/></svg>
        <span style="font-size:1.0625rem; font-weight:900; color:white; letter-spacing:0.02em; text-transform:uppercase;">Wildpfade</span>
      </div>
      <div style="display:flex; align-items:center; gap:2rem;" class="hidden md:flex">
        {['Touren','Guides','Ausrüstung','Kontakt'].map(l => (
          <a href="#" style="font-size:0.8125rem; font-weight:600; color:rgba(255,255,255,0.55); text-decoration:none; letter-spacing:0.06em; transition:color 0.15s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">{l}</a>
        ))}
        <a href="#" style="background:#c4a35a; color:#0c1408; font-size:0.8125rem; font-weight:800; padding:0.5625rem 1.375rem; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase; transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Tour buchen</a>
      </div>
      <button style="background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.6);" class="md:hidden" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <main style="flex:1;">

    <!-- Hero: CSS-Landschaft -->
    <section style="min-height:92vh; position:relative; overflow:hidden; display:flex; align-items:flex-end; padding:0 2rem 4.5rem;">

      <!-- Himmel -->
      <div style="position:absolute; inset:0; background:linear-gradient(180deg, #0a1520 0%, #112840 20%, #1a4a38 55%, #1a3010 75%, #0c1408 100%);" aria-hidden="true"></div>

      <!-- Glow-Licht (Dämmerung) -->
      <div style="position:absolute; top:12%; left:50%; transform:translateX(-50%); width:600px; height:300px; background:radial-gradient(ellipse, rgba(196,163,90,0.12) 0%, transparent 70%); pointer-events:none;" aria-hidden="true"></div>

      <!-- Hintere Bergkette -->
      <div style="position:absolute; bottom:28%; left:0; right:0; height:55%; background:#1a3010; clip-path:polygon(0 100%,0 55%,6% 30%,14% 50%,22% 18%,30% 48%,40% 22%,48% 42%,56% 15%,64% 40%,74% 20%,82% 42%,90% 25%,96% 40%,100% 30%,100% 100%);" aria-hidden="true"></div>

      <!-- Schneelinien auf den Gipfeln -->
      <div style="position:absolute; bottom:28%; left:0; right:0; height:55%; background:rgba(230,240,250,0.1); clip-path:polygon(0 100%,0 55%,6% 30%,7% 32%,5% 55%,14% 50%,21% 18%,23% 21%,22% 48%,30% 48%,39% 22%,42% 26%,40% 42%,48% 42%,55% 15%,57% 18%,56% 40%,64% 40%,73% 20%,75% 23%,74% 40%,82% 42%,89% 25%,91% 28%,90% 42%,96% 40%,100% 30%,100% 100%); pointer-events:none;" aria-hidden="true"></div>

      <!-- Vordere Bergkette (dunkler) -->
      <div style="position:absolute; bottom:8%; left:0; right:0; height:40%; background:#0f1f08; clip-path:polygon(0 100%,0 60%,10% 25%,20% 55%,32% 15%,44% 50%,55% 28%,66% 52%,78% 18%,88% 48%,100% 35%,100% 100%);" aria-hidden="true"></div>

      <!-- Boden / Wald-Linie -->
      <div style="position:absolute; bottom:0; left:0; right:0; height:10%; background:#0c1408;" aria-hidden="true"></div>

      <!-- Overlay für Lesbarkeit -->
      <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(12,20,8,0.92) 0%, rgba(12,20,8,0.4) 35%, rgba(12,20,8,0.1) 70%, transparent 100%);" aria-hidden="true"></div>

      <!-- Hero-Inhalt -->
      <div style="position:relative; max-width:80rem; margin:0 auto; width:100%;">
        <p style="font-size:0.6875rem; font-weight:700; color:#c4a35a; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1.5rem;">Eifel · Alpen · Weltweit</p>
        <h1 style="font-size:clamp(3rem,9vw,7.5rem); font-weight:900; color:white; line-height:0.95; letter-spacing:-0.03em; margin:0 0 2rem; text-transform:uppercase;">
          Raus.<br />
          Weiter.<br />
          <span style="color:#c4a35a;">Wild.</span>
        </h1>
        <p style="font-size:1.0625rem; color:rgba(255,255,255,0.6); line-height:1.75; max-width:46ch; margin:0 0 2.5rem;">
          Geführte Outdoor-Touren und Abenteuerreisen für alle, die Natur nicht nur anschauen – sondern spüren wollen.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:3.5rem;">
          <a href="#" style="background:#c4a35a; color:#0c1408; font-size:0.9375rem; font-weight:800; padding:1rem 2.25rem; text-decoration:none; letter-spacing:0.04em; text-transform:uppercase; transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Touren entdecken</a>
          <a href="#" style="border:1px solid rgba(255,255,255,0.3); color:white; font-size:0.9375rem; font-weight:500; padding:1rem 2rem; text-decoration:none; transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.7)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.3)'">Mehr erfahren</a>
        </div>
        <!-- Kennzahlen -->
        <div style="display:flex; flex-wrap:wrap; gap:3rem; padding-top:2.5rem; border-top:1px solid rgba(255,255,255,0.1);">
          {[['2.500+','Teilnehmer'],['180','Touren'],['12','Länder'],['8 Jahre','Erfahrung']].map(([n,l]) => (
            <div>
              <p style="font-size:1.625rem; font-weight:900; color:#c4a35a; margin:0; line-height:1;">{n}</p>
              <p style="font-size:0.6875rem; color:rgba(255,255,255,0.4); margin:0.25rem 0 0; letter-spacing:0.12em; text-transform:uppercase;">{l}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Erlebnisbereiche: Abwechselnde Layouts -->

    <!-- Erlebnis 1: Bild links, Text rechts -->
    <div style="display:grid; grid-template-columns:1fr; background:#f5efe3; color:#1a1208;" class="lg:grid-cols-2">
      <!-- CSS-Bild Panel: Berglandschaft -->
      <div style="min-height:420px; position:relative; overflow:hidden;">
        <div style="position:absolute; inset:0; background:linear-gradient(180deg,#112840 0%,#1a4a38 35%,#1a3010 65%,#0c1408 100%);"></div>
        <div style="position:absolute; bottom:0; left:0; right:0; height:55%; background:#0f1f08; clip-path:polygon(0 100%,0 45%,15% 10%,30% 48%,45% 15%,60% 45%,75% 22%,88% 48%,100% 30%,100% 100%);"></div>
        <div style="position:absolute; bottom:0; left:0; right:0; height:12%; background:#0c1408;"></div>
        <div style="position:absolute; inset:0; background:linear-gradient(to right, transparent 60%, #f5efe3 100%);" class="hidden lg:block"></div>
        <!-- Label -->
        <div style="position:absolute; top:2rem; left:2rem; background:rgba(12,20,8,0.7); padding:0.375rem 0.875rem; display:flex; align-items:center; gap:0.5rem;">
          <div style="width:6px; height:6px; background:#c4a35a; border-radius:50%;"></div>
          <span style="font-size:0.6875rem; font-weight:700; color:white; letter-spacing:0.14em; text-transform:uppercase;">Bergtouren</span>
        </div>
      </div>
      <!-- Text -->
      <div style="padding:4rem 2.5rem; display:flex; flex-direction:column; justify-content:center;">
        <p style="font-size:0.6875rem; font-weight:700; color:#8b6543; letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1rem;">01 / Gipfelerlebnisse</p>
        <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:900; color:#1a1208; line-height:1.1; margin:0 0 1.25rem; letter-spacing:-0.02em;">Bergtouren<br />&amp; Alpenüberquerungen</h2>
        <p style="font-size:1rem; color:#5a4535; line-height:1.8; margin:0 0 2rem; max-width:42ch;">Von der Halbtageswanderung in der Eifel bis zur mehrtägigen Alpenüberquerung – mit erfahrenen Guides, die jeden Stein kennen.</p>
        <a href="#" style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:800; color:#1a1208; text-decoration:none; letter-spacing:0.08em; text-transform:uppercase; border-bottom:2px solid #c4a35a; padding-bottom:0.25rem; width:fit-content; transition:color 0.15s;" onmouseover="this.style.color='#8b6543'" onmouseout="this.style.color='#1a1208'">Touren ansehen →</a>
      </div>
    </div>

    <!-- Erlebnis 2: Vollbreit mit Overlay-Text (Wald) -->
    <div style="position:relative; min-height:480px; overflow:hidden; display:flex; align-items:flex-end;">
      <!-- CSS Waldlandschaft -->
      <div style="position:absolute; inset:0; background:linear-gradient(180deg,#0a1a04 0%,#1a3b0a 30%,#2d5a10 60%,#1a3010 85%,#0c1408 100%);"></div>
      <!-- Baumsilhouetten-Effekt mit Streifen -->
      <div style="position:absolute; inset:0; background:repeating-linear-gradient(90deg, transparent 0px, transparent 18px, rgba(8,16,4,0.6) 18px, rgba(8,16,4,0.6) 22px, transparent 22px, transparent 45px, rgba(8,16,4,0.5) 45px, rgba(8,16,4,0.5) 50px); background-size:80px 100%; background-position:0 40%;" aria-hidden="true"></div>
      <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(12,20,8,0.95) 0%, rgba(12,20,8,0.5) 40%, transparent 70%);" aria-hidden="true"></div>
      <!-- Label -->
      <div style="position:absolute; top:2rem; right:2rem; background:rgba(12,20,8,0.7); padding:0.375rem 0.875rem; display:flex; align-items:center; gap:0.5rem;">
        <div style="width:6px; height:6px; background:#c4a35a; border-radius:50%;"></div>
        <span style="font-size:0.6875rem; font-weight:700; color:white; letter-spacing:0.14em; text-transform:uppercase;">Wildnis</span>
      </div>
      <!-- Text-Overlay -->
      <div style="position:relative; padding:3rem 2.5rem; max-width:80rem; margin:0 auto; width:100%; display:grid; grid-template-columns:1fr; gap:2rem;" class="lg:grid-cols-2">
        <div>
          <p style="font-size:0.6875rem; font-weight:700; color:#c4a35a; letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1rem;">02 / Waldabenteuer</p>
          <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:900; color:white; line-height:1.1; margin:0; letter-spacing:-0.02em;">Zelten &amp;<br />Wildnis-Survival</h2>
        </div>
        <div style="display:flex; flex-direction:column; justify-content:flex-end;">
          <p style="font-size:1rem; color:rgba(255,255,255,0.65); line-height:1.75; margin:0 0 1.5rem; max-width:40ch;">Mit Guide durch unberührte Wälder – Ausrüstung, Feuermachen, Navigation. Kein Strom, keine Ablenkung. Nur Natur.</p>
          <a href="#" style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:800; color:#c4a35a; text-decoration:none; letter-spacing:0.08em; text-transform:uppercase; border-bottom:1px solid rgba(196,163,90,0.4); padding-bottom:0.25rem; width:fit-content; transition:border-color 0.15s;" onmouseover="this.style.borderColor='#c4a35a'" onmouseout="this.style.borderColor='rgba(196,163,90,0.4)'">Mehr erfahren →</a>
        </div>
      </div>
    </div>

    <!-- Erlebnis 3: Text links, Wasser-Panel rechts -->
    <div style="display:grid; grid-template-columns:1fr; background:#f5efe3; color:#1a1208;" class="lg:grid-cols-2">
      <!-- Text -->
      <div style="padding:4rem 2.5rem; display:flex; flex-direction:column; justify-content:center; order:2;" class="lg:order-1">
        <p style="font-size:0.6875rem; font-weight:700; color:#8b6543; letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1rem;">03 / Wildwasser</p>
        <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:900; color:#1a1208; line-height:1.1; margin:0 0 1.25rem; letter-spacing:-0.02em;">Kanu, Kajak<br />&amp; Rafting</h2>
        <p style="font-size:1rem; color:#5a4535; line-height:1.8; margin:0 0 2rem; max-width:42ch;">Ruhige Kanutouren auf der Sauer bis zum wilden Rafting in den Alpen – für Einsteiger und Fortgeschrittene.</p>
        <a href="#" style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:800; color:#1a1208; text-decoration:none; letter-spacing:0.08em; text-transform:uppercase; border-bottom:2px solid #c4a35a; padding-bottom:0.25rem; width:fit-content; transition:color 0.15s;" onmouseover="this.style.color='#8b6543'" onmouseout="this.style.color='#1a1208'">Touren ansehen →</a>
      </div>
      <!-- CSS-Bild Panel: Wasser -->
      <div style="min-height:420px; position:relative; overflow:hidden; order:1;" class="lg:order-2">
        <div style="position:absolute; inset:0; background:linear-gradient(160deg,#0a2840 0%,#0d4a6e 30%,#1a6a80 55%,#1a5038 80%,#0c1408 100%);"></div>
        <!-- Welleneffekt -->
        <div style="position:absolute; top:30%; left:0; right:0; height:40%; background:rgba(100,180,220,0.08); clip-path:polygon(0 50%,5% 40%,10% 50%,15% 35%,20% 48%,25% 38%,30% 52%,35% 40%,40% 50%,45% 38%,50% 52%,55% 40%,60% 52%,65% 38%,70% 50%,75% 40%,80% 52%,85% 40%,90% 50%,95% 42%,100% 50%,100% 100%,0 100%);" aria-hidden="true"></div>
        <div style="position:absolute; top:40%; left:0; right:0; height:40%; background:rgba(100,180,220,0.06); clip-path:polygon(0 60%,8% 45%,16% 58%,24% 42%,32% 56%,40% 44%,48% 58%,56% 44%,64% 58%,72% 44%,80% 58%,88% 44%,100% 55%,100% 100%,0 100%);" aria-hidden="true"></div>
        <div style="position:absolute; inset:0; background:linear-gradient(to left, transparent 60%, #f5efe3 100%);" class="hidden lg:block"></div>
        <!-- Label -->
        <div style="position:absolute; top:2rem; right:2rem; background:rgba(12,20,8,0.7); padding:0.375rem 0.875rem; display:flex; align-items:center; gap:0.5rem;">
          <div style="width:6px; height:6px; background:#c4a35a; border-radius:50%;"></div>
          <span style="font-size:0.6875rem; font-weight:700; color:white; letter-spacing:0.14em; text-transform:uppercase;">Wildwasser</span>
        </div>
      </div>
    </div>

    <!-- Für wen geeignet -->
    <section style="background:#1a2e10; padding:5rem 2rem;">
      <div style="max-width:80rem; margin:0 auto;">
        <div style="display:grid; grid-template-columns:1fr; gap:3rem; align-items:start;" class="lg:grid-cols-[2fr_3fr]">
          <div>
            <p style="font-size:0.6875rem; font-weight:700; color:#c4a35a; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1rem;">Für wen</p>
            <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:900; color:white; line-height:1.15; margin:0; letter-spacing:-0.02em;">Für jeden,<br />der draußen mehr will.</h2>
          </div>
          <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1.25rem;">
            {[
              { titel:'Einsteiger',      text:'Kein Vorwissen nötig. Unsere Guides erklären alles – sicher und in Ihrem Tempo.' },
              { titel:'Familien',        text:'Altersgerechte Touren, die Kindern und Erwachsenen gleichermaßen etwas bieten.' },
              { titel:'Gruppen',         text:'Teambuilding, Vereinsausflüge, Freundesgruppen – ab 4 Personen buchbar.' },
              { titel:'Erfahrene',       text:'Für Profis, die neue Herausforderungen suchen: anspruchsvolle Routen auf Anfrage.' },
            ].map(g => (
              <div style="border-top:2px solid rgba(196,163,90,0.3); padding-top:1.25rem; transition:border-color 0.15s;" onmouseover="this.style.borderTopColor='#c4a35a'" onmouseout="this.style.borderTopColor='rgba(196,163,90,0.3)'">
                <h3 style="font-size:0.9375rem; font-weight:800; color:white; margin:0 0 0.5rem;">{g.titel}</h3>
                <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.7; margin:0;">{g.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background:#c4a35a; padding:5.5rem 2rem; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; right:0; width:400px; height:400px; background:radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); pointer-events:none;" aria-hidden="true"></div>
      <div style="max-width:80rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:3rem; align-items:center; position:relative;" class="lg:grid-cols-[3fr_2fr]">
        <div>
          <p style="font-size:0.6875rem; font-weight:800; color:rgba(12,20,8,0.5); letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1rem;">Nächste Expedition</p>
          <h2 style="font-size:clamp(1.75rem,4.5vw,3.25rem); font-weight:900; color:#0c1408; line-height:1.05; margin:0; letter-spacing:-0.025em; text-transform:uppercase;">Ihre nächste<br />Tour wartet.</h2>
        </div>
        <div style="display:flex; flex-direction:column; gap:1rem; align-items:flex-start;" class="lg:items-end">
          <a href="#" style="background:#0c1408; color:#c4a35a; font-size:0.9375rem; font-weight:800; padding:1.0625rem 2.25rem; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase; transition:opacity 0.15s; white-space:nowrap;" onmouseover="this.style.opacity='0.82'" onmouseout="this.style.opacity='1'">Jetzt Platz sichern</a>
          <span style="font-size:0.875rem; color:rgba(12,20,8,0.55); font-weight:700;">Plätze sind begrenzt.</span>
        </div>
      </div>
    </section>

    <!-- Geeignet für -->
    <section style="padding:1.75rem 2rem; background:#0c1408; border-top:1px solid rgba(255,255,255,0.06);">
      <div style="max-width:80rem; margin:0 auto;">
        <p style="font-size:0.875rem; color:rgba(255,255,255,0.3); margin:0; line-height:1.6;">
          <strong style="color:rgba(255,255,255,0.55); font-weight:600;">Geeignet für:</strong>
          Outdoor-Anbieter, Reiseveranstalter, Campingplätze, Naturparks, Sportschulen, Abenteuerveranstalter und Tourismusregionen.
        </p>
      </div>
    </section>

  </main>

  <DemoFooter />
</div>
</BaseLayout>
