---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
---

<BaseLayout title="Kindlich & Verspielt – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif; background:#fffbf5;">

  <DemoHeader showBack currentStyle="Kindlich & Verspielt" />

  <!-- Nav -->
  <nav style="background:white; box-shadow:0 2px 12px rgba(0,0,0,0.06); position:sticky; top:42px; z-index:40;">
    <div style="max-width:72rem; margin:0 auto; padding:0 2rem; height:64px; display:flex; align-items:center; justify-content:space-between;">
      <div style="display:flex; align-items:center; gap:0.625rem;">
        <div style="width:34px; height:34px; background:linear-gradient(135deg,#fb923c,#f59e0b); border-radius:50%; flex-shrink:0;"></div>
        <span style="font-size:1rem; font-weight:800; color:#fb923c;">Kleine Entdecker</span>
      </div>
      <div style="display:flex; align-items:center; gap:1.875rem;" class="hidden md:flex">
        {['Angebote','Über uns','Elterninfos','Kontakt'].map(l => (
          <a href="#" style="font-size:0.875rem; color:#6b5e50; text-decoration:none; transition:color 0.15s;" onmouseover="this.style.color='#fb923c'" onmouseout="this.style.color='#6b5e50'">{l}</a>
        ))}
        <a href="#" style="background:#fb923c; color:white; font-size:0.875rem; font-weight:700; padding:0.5625rem 1.375rem; border-radius:100px; text-decoration:none; transition:opacity 0.15s; box-shadow:0 3px 10px rgba(251,146,60,0.3);" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Anmelden</a>
      </div>
      <button style="background:none; border:none; cursor:pointer; color:#6b5e50;" class="md:hidden" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <main style="flex:1;">

    <!-- Hero -->
    <section style="background:#fffbf5; padding:5rem 2rem 6rem; position:relative; overflow:hidden;">

      <!-- CSS-Blob-Dekorationen -->
      <div style="position:absolute; top:-10%; right:-8%; width:440px; height:440px; background:#fde68a; border-radius:62% 38% 70% 30% / 45% 62% 38% 55%; opacity:0.35; pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; bottom:0%; left:-10%; width:380px; height:380px; background:#bfdbfe; border-radius:38% 62% 30% 70% / 62% 38% 70% 30%; opacity:0.38; pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; top:30%; right:18%; width:110px; height:110px; background:#bbf7d0; border-radius:50%; opacity:0.55; pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; top:65%; right:6%; width:72px; height:72px; background:#e9d5ff; border-radius:50%; opacity:0.6; pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; top:18%; left:18%; width:55px; height:55px; background:#fca5a5; border-radius:50%; opacity:0.45; pointer-events:none;" aria-hidden="true"></div>

      <div style="max-width:72rem; margin:0 auto; position:relative; text-align:center;">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; background:#fff3e0; border-radius:100px; padding:0.4375rem 1.25rem; margin-bottom:2rem;">
          <div style="width:7px; height:7px; background:#fb923c; border-radius:50%;"></div>
          <span style="font-size:0.75rem; font-weight:700; color:#c2410c; letter-spacing:0.06em;">Kreative Kurse für Kinder · Duisburg</span>
        </div>
        <h1 style="font-size:clamp(2.25rem,5.5vw,4rem); font-weight:800; color:#1c1410; line-height:1.15; letter-spacing:-0.02em; margin:0 0 1.5rem;">
          Entdecken, Lernen,<br />
          <span style="color:#fb923c;">Wachsen.</span>
        </h1>
        <p style="font-size:1.125rem; color:#6b5e50; line-height:1.8; max-width:46ch; margin:0 auto 2.5rem;">
          Bei uns erleben Kinder Neues mit allen Sinnen – in kleinen Gruppen, mit viel Freude und einem Team, dem ihr Wohlbefinden wirklich am Herzen liegt.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="#" style="background:#fb923c; color:white; font-size:1rem; font-weight:700; padding:0.9375rem 2.25rem; border-radius:100px; text-decoration:none; transition:opacity 0.15s; box-shadow:0 4px 16px rgba(251,146,60,0.35);" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">Angebote entdecken</a>
          <a href="#" style="background:white; color:#1c1410; font-size:1rem; font-weight:600; padding:0.9375rem 2.25rem; border-radius:100px; text-decoration:none; border:2px solid #e8e0d5; transition:border-color 0.15s;" onmouseover="this.style.borderColor='#fb923c'" onmouseout="this.style.borderColor='#e8e0d5'">Mehr erfahren</a>
        </div>
      </div>
    </section>

    <!-- Angebotsbereiche -->
    <section style="background:white; padding:5rem 2rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <div style="text-align:center; margin-bottom:3.5rem;">
          <p style="font-size:0.75rem; font-weight:700; color:#fb923c; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 0.5rem;">Unsere Angebote</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#1c1410; margin:0; letter-spacing:-0.02em;">Was wir gemeinsam erleben.</h2>
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.5rem;">

          <!-- Kreatives Gestalten -->
          <div
            style="background:#fff8ed; border-radius:24px; padding:2rem; border:2px solid #fed7aa; transition:transform 0.2s,box-shadow 0.2s;"
            onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 16px 36px rgba(251,146,60,0.14)'"
            onmouseout="this.style.transform='none';this.style.boxShadow='none'"
          >
            <div style="width:52px; height:52px; background:#fb923c; border-radius:16px; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:800; color:#1c1410; margin:0 0 0.625rem;">Kreatives Gestalten</h3>
            <p style="font-size:0.9375rem; color:#6b5e50; line-height:1.7; margin:0 0 1.375rem;">Malen, Basteln, Töpfern – Kinder entfalten ihre Kreativität in kleinen Gruppen mit vielfältigen Materialien.</p>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
              {['3–6 Jahre','6–10 Jahre'].map(t => (
                <span style="font-size:0.75rem; font-weight:600; color:#c2410c; background:#ffedd5; padding:0.25rem 0.75rem; border-radius:100px;">{t}</span>
              ))}
            </div>
          </div>

          <!-- Bewegung & Spiel -->
          <div
            style="background:#eff6ff; border-radius:24px; padding:2rem; border:2px solid #bfdbfe; transition:transform 0.2s,box-shadow 0.2s;"
            onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 16px 36px rgba(96,165,250,0.14)'"
            onmouseout="this.style.transform='none';this.style.boxShadow='none'"
          >
            <div style="width:52px; height:52px; background:#60a5fa; border-radius:16px; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:800; color:#1c1410; margin:0 0 0.625rem;">Bewegung & Spiel</h3>
            <p style="font-size:0.9375rem; color:#6b5e50; line-height:1.7; margin:0 0 1.375rem;">Tanz, Motorik und Spielgruppen – Kinder bewegen sich, erkunden ihren Körper und schließen Freundschaften.</p>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
              {['1–3 Jahre','3–6 Jahre'].map(t => (
                <span style="font-size:0.75rem; font-weight:600; color:#1d4ed8; background:#dbeafe; padding:0.25rem 0.75rem; border-radius:100px;">{t}</span>
              ))}
            </div>
          </div>

          <!-- Sprache & Lesen -->
          <div
            style="background:#f0fdf4; border-radius:24px; padding:2rem; border:2px solid #bbf7d0; transition:transform 0.2s,box-shadow 0.2s;"
            onmouseover="this.style.transform='translateY(-5px)';this.style.boxShadow='0 16px 36px rgba(74,222,128,0.14)'"
            onmouseout="this.style.transform='none';this.style.boxShadow='none'"
          >
            <div style="width:52px; height:52px; background:#4ade80; border-radius:16px; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:800; color:#1c1410; margin:0 0 0.625rem;">Sprache & Lesen</h3>
            <p style="font-size:0.9375rem; color:#6b5e50; line-height:1.7; margin:0 0 1.375rem;">Vorlesestunden, Sprachspiele und erste Lese-Erlebnisse – spielerisch und immer in der richtigen Dosierung.</p>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
              {['4–7 Jahre','6–10 Jahre'].map(t => (
                <span style="font-size:0.75rem; font-weight:600; color:#166534; background:#dcfce7; padding:0.25rem 0.75rem; border-radius:100px;">{t}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Vertrauensbereich für Eltern -->
    <section style="background:#fff9f0; padding:5rem 2rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <div style="text-align:center; margin-bottom:3.5rem;">
          <p style="font-size:0.75rem; font-weight:700; color:#fb923c; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 0.5rem;">Für Eltern</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#1c1410; margin:0; letter-spacing:-0.02em;">Ihr Kind ist bei uns gut aufgehoben.</h2>
        </div>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.5rem;">
          {[
            {
              farbe:'#fb923c', bg:'#fff8ed',
              icon:'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
              titel:'Qualifiziertes Team',
              text:'Alle Kursleiterinnen haben eine pädagogische Ausbildung und langjährige Erfahrung mit Kindern.',
            },
            {
              farbe:'#60a5fa', bg:'#eff6ff',
              icon:'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
              titel:'Kleine Gruppen',
              text:'Maximal 8 Kinder pro Kurs – damit jedes Kind die Aufmerksamkeit bekommt, die es verdient.',
            },
            {
              farbe:'#4ade80', bg:'#f0fdf4',
              icon:'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
              titel:'Offene Kommunikation',
              text:'Regelmäßige Updates, kurze Wege – Sie sind immer informiert, was Ihr Kind erlebt.',
            },
            {
              farbe:'#c084fc', bg:'#faf5ff',
              icon:'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
              titel:'Mit Herz dabei',
              text:'Wir lieben, was wir tun. Und das merkt man: in jeder Stunde, in jeder Idee, in jedem Lächeln.',
            },
          ].map(v => (
            <div style={`background:${v.bg}; border-radius:20px; padding:1.75rem;`}>
              <div style={`width:44px; height:44px; background:${v.farbe}; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:1rem;`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d={v.icon}/>
                </svg>
              </div>
              <h3 style="font-size:1rem; font-weight:800; color:#1c1410; margin:0 0 0.5rem;">{v.titel}</h3>
              <p style="font-size:0.875rem; color:#6b5e50; line-height:1.7; margin:0;">{v.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background:linear-gradient(135deg,#fb923c 0%,#f97316 100%); padding:5rem 2rem; position:relative; overflow:hidden;">
      <div style="position:absolute; top:-40%; right:-8%; width:520px; height:520px; background:rgba(255,255,255,0.07); border-radius:50%; pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; bottom:-35%; left:-6%; width:380px; height:380px; background:rgba(255,255,255,0.05); border-radius:50%; pointer-events:none;" aria-hidden="true"></div>
      <div style="max-width:72rem; margin:0 auto; text-align:center; position:relative;">
        <h2 style="font-size:clamp(1.75rem,4vw,3rem); font-weight:800; color:white; margin:0 0 1rem; letter-spacing:-0.02em;">Neugierig geworden?</h2>
        <p style="font-size:1.0625rem; color:rgba(255,255,255,0.88); line-height:1.75; margin:0 auto 2.5rem; max-width:44ch;">Schnupperstunden sind jederzeit möglich. Melden Sie sich – wir freuen uns auf Sie und Ihr Kind.</p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="#" style="background:white; color:#f97316; font-size:1rem; font-weight:800; padding:1rem 2.25rem; border-radius:100px; text-decoration:none; transition:opacity 0.15s; box-shadow:0 4px 20px rgba(0,0,0,0.12);" onmouseover="this.style.opacity='0.92'" onmouseout="this.style.opacity='1'">Anmeldung anfragen</a>
          <a href="#" style="background:rgba(255,255,255,0.15); border:2px solid rgba(255,255,255,0.45); color:white; font-size:1rem; font-weight:600; padding:1rem 2.25rem; border-radius:100px; text-decoration:none; transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.85)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.45)'">Alle Kurse ansehen</a>
        </div>
      </div>
    </section>

    <!-- Geeignet für -->
    <section style="padding:1.75rem 2rem; background:#fffbf5; border-top:1px solid #e8e0d5;">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.875rem; color:#9b8e80; margin:0; line-height:1.6;">
          <strong style="color:#5a4535; font-weight:600;">Geeignet für:</strong>
          Kindertagesstätten, Kinder- und Jugendkurse, Lernzentren, Musikschulen, Kreativwerkstätten, Familienberatung und Freizeitangebote für Kinder.
        </p>
      </div>
    </section>

  </main>

  <DemoFooter />
</div>
</BaseLayout>
