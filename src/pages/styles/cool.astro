---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
---

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .ticker-track { animation: marquee 24s linear infinite; }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
</style>

<BaseLayout title="Cool & Dynamisch – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif; background:#090910; color:white;">

  <DemoHeader showBack currentStyle="Cool & Dynamisch" />

  <!-- Nav -->
  <nav style="background:rgba(9,9,16,0.92); backdrop-filter:blur(12px); border-bottom:1px solid rgba(255,255,255,0.06); position:sticky; top:42px; z-index:40;">
    <div style="max-width:80rem; margin:0 auto; padding:0 2rem; height:60px; display:flex; align-items:center; justify-content:space-between;">
      <span style="font-size:1.125rem; font-weight:900; color:#a3f600; letter-spacing:-0.01em; text-transform:uppercase;">KODE.</span>
      <div style="display:flex; align-items:center; gap:2.25rem;" class="hidden md:flex">
        {['Work','Services','About','Contact'].map(l => (
          <a href="#" style="font-size:0.75rem; font-weight:700; color:rgba(255,255,255,0.4); text-decoration:none; letter-spacing:0.14em; text-transform:uppercase; transition:color 0.15s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">{l}</a>
        ))}
        <a href="#" style="background:#a3f600; color:#090910; font-size:0.75rem; font-weight:800; padding:0.5rem 1.25rem; text-decoration:none; letter-spacing:0.1em; text-transform:uppercase; transition:opacity 0.15s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Start</a>
      </div>
      <button style="background:none; border:none; cursor:pointer; color:rgba(255,255,255,0.5);" class="md:hidden" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <main style="flex:1;">

    <!-- Hero -->
    <section style="background:#090910; min-height:92vh; display:flex; align-items:center; padding:5rem 2rem 7rem; position:relative; overflow:hidden;">

      <!-- Akzent-Glows -->
      <div style="position:absolute; top:15%; right:8%; width:560px; height:560px; background:radial-gradient(circle,rgba(163,246,0,0.06) 0%,transparent 65%); pointer-events:none;" aria-hidden="true"></div>
      <div style="position:absolute; bottom:10%; left:0%; width:360px; height:360px; background:radial-gradient(circle,rgba(163,246,0,0.04) 0%,transparent 65%); pointer-events:none;" aria-hidden="true"></div>

      <div style="max-width:80rem; margin:0 auto; width:100%; position:relative;">

        <!-- Label -->
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:3rem;">
          <div style="width:8px; height:8px; background:#a3f600; border-radius:50%;"></div>
          <span style="font-size:0.6875rem; font-weight:700; color:rgba(255,255,255,0.35); letter-spacing:0.22em; text-transform:uppercase;">Digital Studio · Duisburg</span>
        </div>

        <!-- Headline -->
        <h1 style="font-size:clamp(3.5rem,11vw,9rem); font-weight:900; color:white; line-height:0.93; letter-spacing:-0.04em; margin:0 0 3rem; text-transform:uppercase;">
          Wir bauen<br />
          <span style="color:#a3f600;">digitale</span><br />
          Produkte.
        </h1>

        <div style="display:grid; grid-template-columns:1fr; gap:2.5rem; align-items:end;" class="lg:grid-cols-[1fr_auto]">
          <p style="font-size:1.0625rem; color:rgba(255,255,255,0.45); line-height:1.8; max-width:46ch; margin:0;">
            Websites, Apps und digitale Erlebnisse, die auffallen – durchdacht, schnell und ohne Kompromisse.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:1rem;">
            <a href="#" style="background:#a3f600; color:#090910; font-size:0.9375rem; font-weight:800; padding:1rem 2.25rem; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase; transition:opacity 0.15s; white-space:nowrap;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Projekt starten</a>
            <a href="#" style="border:1px solid rgba(255,255,255,0.18); color:white; font-size:0.9375rem; font-weight:500; padding:1rem 2.25rem; text-decoration:none; white-space:nowrap; transition:border-color 0.15s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.55)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.18)'">Arbeiten ansehen</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Ticker-Streifen -->
    <div style="background:#a3f600; padding:0.75rem 0; overflow:hidden;">
      <div class="ticker-track" style="display:flex; width:max-content; white-space:nowrap;">
        <span style="font-size:0.6875rem; font-weight:800; color:#090910; letter-spacing:0.2em; text-transform:uppercase; padding-right:4rem;">DIGITAL STUDIO &nbsp;·&nbsp; WEB DESIGN &nbsp;·&nbsp; APP ENTWICKLUNG &nbsp;·&nbsp; BRANDING &nbsp;·&nbsp; UX&nbsp;/&nbsp;UI &nbsp;·&nbsp; PRODUCT DESIGN &nbsp;·&nbsp; DIGITAL STUDIO &nbsp;·&nbsp; WEB DESIGN &nbsp;·&nbsp; APP ENTWICKLUNG &nbsp;·&nbsp; BRANDING &nbsp;·&nbsp; UX&nbsp;/&nbsp;UI &nbsp;·&nbsp; PRODUCT DESIGN &nbsp;·&nbsp;</span>
        <span style="font-size:0.6875rem; font-weight:800; color:#090910; letter-spacing:0.2em; text-transform:uppercase; padding-right:4rem;">DIGITAL STUDIO &nbsp;·&nbsp; WEB DESIGN &nbsp;·&nbsp; APP ENTWICKLUNG &nbsp;·&nbsp; BRANDING &nbsp;·&nbsp; UX&nbsp;/&nbsp;UI &nbsp;·&nbsp; PRODUCT DESIGN &nbsp;·&nbsp; DIGITAL STUDIO &nbsp;·&nbsp; WEB DESIGN &nbsp;·&nbsp; APP ENTWICKLUNG &nbsp;·&nbsp; BRANDING &nbsp;·&nbsp; UX&nbsp;/&nbsp;UI &nbsp;·&nbsp; PRODUCT DESIGN &nbsp;·&nbsp;</span>
      </div>
    </div>

    <!-- Features: Schräger Block -->
    <div style="background:#0f0f1a; transform:skewY(-2deg); margin:3rem 0; position:relative; z-index:1;">
      <section style="transform:skewY(2deg); padding:6rem 2rem;">
        <div style="max-width:80rem; margin:0 auto;">

          <div style="display:flex; align-items:center; gap:1.5rem; margin-bottom:4rem;">
            <span style="font-size:0.6875rem; font-weight:800; color:#a3f600; letter-spacing:0.22em; text-transform:uppercase; white-space:nowrap;">Was wir tun</span>
            <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
          </div>

          <div style="display:flex; flex-direction:column;">
            {[
              { nr:'01', titel:'Webseiten & Landingpages', text:'Von schnellen One-Pagern bis zu komplexen Plattformen – immer mit Fokus auf Conversion und Performance.' },
              { nr:'02', titel:'App-Entwicklung',          text:'Native und Progressive Web Apps, die sich wie selbstverständlich anfühlen. Kein Template, kein Fertigbaukasten.' },
              { nr:'03', titel:'Brand & Visual Identity',  text:'Logo, Farben, Typografie – ein System, das auf jeder Fläche funktioniert und im Gedächtnis bleibt.' },
              { nr:'04', titel:'UX Research & Strategy',   text:'Wir denken vor, bevor wir bauen. Nutzerinterviews, Wireframes, Prototypen – dann erst Code.' },
            ].map(f => (
              <div
                style="display:grid; grid-template-columns:3.5rem 1fr 1.5rem; align-items:center; gap:2rem; padding:1.875rem 0; border-top:1px solid rgba(255,255,255,0.06); cursor:default; transition:padding-left 0.2s;"
                onmouseover="this.style.paddingLeft='0.75rem'; this.querySelector('.fn').style.color='#a3f600'; this.querySelector('.fa').style.opacity='1';"
                onmouseout="this.style.paddingLeft='0'; this.querySelector('.fn').style.color='rgba(255,255,255,0.12)'; this.querySelector('.fa').style.opacity='0';"
              >
                <span class="fn" style="font-size:0.6875rem; font-weight:800; color:rgba(255,255,255,0.12); letter-spacing:0.12em; transition:color 0.2s;">{f.nr}</span>
                <div>
                  <h3 style="font-size:clamp(1.0625rem,2vw,1.375rem); font-weight:800; color:white; margin:0 0 0.375rem; letter-spacing:-0.015em;">{f.titel}</h3>
                  <p style="font-size:0.9375rem; color:rgba(255,255,255,0.38); line-height:1.65; margin:0;">{f.text}</p>
                </div>
                <span class="fa" style="color:#a3f600; opacity:0; transition:opacity 0.2s; font-size:1.125rem;">→</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <!-- Projekte -->
    <section style="background:#090910; padding:6rem 2rem;">
      <div style="max-width:80rem; margin:0 auto;">

        <div style="display:flex; align-items:center; gap:1.5rem; margin-bottom:4rem;">
          <span style="font-size:0.6875rem; font-weight:800; color:#a3f600; letter-spacing:0.22em; text-transform:uppercase; white-space:nowrap;">Ausgewählte Arbeiten</span>
          <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
        </div>

        <div style="display:flex; flex-direction:column;">
          {[
            { nr:'001', name:'Pulse App',    typ:'App · iOS / Android', jahr:'2024' },
            { nr:'002', name:'Norda Stores', typ:'E-Commerce · Web',    jahr:'2024' },
            { nr:'003', name:'MXVR Studio',  typ:'Branding · Web',      jahr:'2023' },
            { nr:'004', name:'Flowbase',     typ:'SaaS · Dashboard',    jahr:'2023' },
          ].map(p => (
            <a
              href="#"
              style="display:grid; grid-template-columns:3.5rem 1fr auto auto; align-items:center; gap:2rem; padding:1.75rem 0; border-top:1px solid rgba(255,255,255,0.06); text-decoration:none; transition:padding-left 0.2s;"
              onmouseover="this.style.paddingLeft='0.75rem'; this.querySelector('.pn').style.color='#a3f600'; this.querySelector('.pa').style.opacity='1';"
              onmouseout="this.style.paddingLeft='0'; this.querySelector('.pn').style.color='white'; this.querySelector('.pa').style.opacity='0';"
            >
              <span style="font-size:0.6875rem; font-weight:800; color:rgba(255,255,255,0.15); letter-spacing:0.1em;">{p.nr}</span>
              <span class="pn" style="font-size:clamp(1.125rem,2.5vw,1.75rem); font-weight:800; color:white; letter-spacing:-0.025em; transition:color 0.2s;">{p.name}</span>
              <span style="font-size:0.8125rem; color:rgba(255,255,255,0.28); letter-spacing:0.05em; white-space:nowrap;" class="hidden sm:block">{p.typ}</span>
              <div style="display:flex; align-items:center; gap:1rem; flex-shrink:0;">
                <span style="font-size:0.8125rem; color:rgba(255,255,255,0.22);">{p.jahr}</span>
                <span class="pa" style="color:#a3f600; opacity:0; transition:opacity 0.2s;">↗</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA: Lime bg mit diagonalem Einstieg -->
    <section style="background:#a3f600; padding:6rem 2rem; position:relative; overflow:hidden;">
      <!-- Diagonaler Keil oben -->
      <div style="position:absolute; top:0; left:0; right:0; height:3.5rem; background:#090910; clip-path:polygon(0 0,100% 0,0 100%);" aria-hidden="true"></div>

      <div style="max-width:80rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:3rem; align-items:center; position:relative;" class="lg:grid-cols-[3fr_2fr]">
        <div>
          <p style="font-size:0.6875rem; font-weight:800; color:rgba(9,9,16,0.45); letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1.25rem;">Nächster Schritt</p>
          <h2 style="font-size:clamp(2rem,5.5vw,4rem); font-weight:900; color:#090910; margin:0; line-height:0.95; letter-spacing:-0.035em; text-transform:uppercase;">
            Ihr nächstes<br />Projekt.
          </h2>
        </div>
        <div style="display:flex; flex-direction:column; gap:1rem; align-items:flex-start;" class="lg:items-end">
          <a href="#" style="background:#090910; color:#a3f600; font-size:0.9375rem; font-weight:800; padding:1.0625rem 2.25rem; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase; transition:opacity 0.15s; white-space:nowrap;" onmouseover="this.style.opacity='0.82'" onmouseout="this.style.opacity='1'">Gespräch vereinbaren</a>
          <span style="font-size:0.875rem; color:rgba(9,9,16,0.5); font-weight:700;">hello@kode.studio</span>
        </div>
      </div>
    </section>

    <!-- Geeignet für -->
    <section style="padding:1.75rem 2rem; background:#090910; border-top:1px solid rgba(255,255,255,0.06);">
      <div style="max-width:80rem; margin:0 auto;">
        <p style="font-size:0.875rem; color:rgba(255,255,255,0.28); margin:0; line-height:1.6;">
          <strong style="color:rgba(255,255,255,0.55); font-weight:600;">Geeignet für:</strong>
          Digitale Agenturen, Tech-Startups, SaaS-Produkte, Event-Marken, Kreativstudios und junge Unternehmen mit Anspruch.
        </p>
      </div>
    </section>

  </main>

  <DemoFooter />
</div>
</BaseLayout>
