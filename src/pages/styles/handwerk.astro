---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
import DemoCTA from '../../components/DemoCTA.astro';
---

<BaseLayout title="Handwerk & Bodenständig – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif;">
  <DemoHeader showBack currentStyle="Handwerk & Bodenständig" />

  <div style="flex:1; background:#fef9f0;">

    <!-- Nav -->
    <nav style="background:#fef9f0; border-bottom:2px solid #292524; position:sticky; top:42px; z-index:40;">
      <div style="max-width:72rem; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:64px;">
        <div>
          <span style="font-size:1.25rem; font-weight:900; color:#292524; letter-spacing:-0.02em;">Tischler</span>
          <span style="font-size:1.25rem; font-weight:900; color:#b45309; letter-spacing:-0.02em;">Brandt</span>
        </div>
        <div style="display:flex; align-items:center; gap:1.75rem;" class="hidden md:flex">
          {['Leistungen','Galerie','Über uns','Kontakt'].map(l => (
            <a href="#" style="font-size:0.875rem; font-weight:600; color:#44403c; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#b45309'" onmouseout="this.style.color='#44403c'">{l}</a>
          ))}
          <a href="#" style="font-size:0.8125rem; color:#44403c; font-weight:600; display:flex; align-items:center; gap:0.375rem; text-decoration:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            0203 · 123 456
          </a>
        </div>
        <button style="background:none; border:none; cursor:pointer; color:#44403c;" class="md:hidden" aria-label="Menü">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>

    <!-- Hero: Asymmetric -->
    <section style="overflow:hidden;">
      <div style="max-width:72rem; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:1fr; gap:0;" class="lg:grid-cols-[3fr_2fr]">

        <!-- Text: groß, asymmetrisch -->
        <div style="padding:4rem 0 4rem; display:flex; flex-direction:column; justify-content:center;">
          <p style="font-size:0.75rem; font-weight:700; color:#b45309; letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1.25rem;">Tischlermeister · Duisburg · seit 1992</p>
          <h1 style="font-size:clamp(2.75rem,7vw,5.5rem); font-weight:900; color:#292524; line-height:0.95; letter-spacing:-0.03em; margin:0 0 2rem;">
            Holz.<br />
            <span style="color:#b45309;">Handwerk.</span><br />
            Herzblut.
          </h1>
          <div style="width:3rem; height:3px; background:#b45309; margin-bottom:1.5rem;"></div>
          <p style="color:#78716c; font-size:1.0625rem; line-height:1.75; max-width:42ch; margin:0 0 2.5rem;">
            Massivholzmöbel und Innenausbau nach Maß. Keine Katalogware, keine Kompromisse – nur ehrliches Handwerk, das hält.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:0.875rem;">
            <a href="#" style="background:#292524; color:white; font-size:0.875rem; font-weight:700; padding:1rem 2rem; text-decoration:none; transition:background 0.2s;" onmouseover="this.style.background='#44403c'" onmouseout="this.style.background='#292524'">Kostenlos anfragen</a>
            <a href="#" style="border:2px solid #292524; color:#292524; font-size:0.875rem; font-weight:700; padding:1rem 2rem; text-decoration:none; transition:background 0.2s;" onmouseover="this.style.background='#fef3c7'" onmouseout="this.style.background='transparent'">Galerie ansehen</a>
          </div>
        </div>

        <!-- Right: Earthy color block -->
        <div style="background:linear-gradient(160deg,#b45309,#92400e); display:flex; align-items:center; justify-content:center; padding:3rem; min-height:340px;" class="hidden lg:flex" aria-hidden="true">
          <div style="text-align:center; color:white;">
            <p style="font-size:4rem; font-weight:900; line-height:1; margin:0;">30+</p>
            <p style="font-size:0.875rem; opacity:0.75; letter-spacing:0.1em; text-transform:uppercase; margin:0.5rem 0 0;">Jahre Erfahrung</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services mit Nummern -->
    <section style="background:white; padding:5rem 1.5rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:900; color:#292524; margin:0 0 3rem; letter-spacing:-0.02em;">Was wir machen.</h2>
        <div style="display:flex; flex-direction:column; gap:0;">
          {[
            { nr:'01', title:'Massivholzmöbel', text:'Tische, Schränke, Regale – nach Ihren Maßen und Vorstellungen gefertigt.' },
            { nr:'02', title:'Innenausbau & Küchen', text:'Kompletter Innenausbau vom Dachboden bis zum Keller – sauber und termingerecht.' },
            { nr:'03', title:'Türen & Fenster', text:'Einbau, Reparatur und Restaurierung von Holztüren und -fenstern.' },
          ].map((s,i) => (
            <div style={`display:flex; gap:2rem; align-items:flex-start; padding:2rem 0; ${i>0?'border-top:1px solid #e7e5e4;':''}`}>
              <span style="font-size:2.5rem; font-weight:900; color:#e7e5e4; line-height:1; min-width:3rem; font-variant-numeric:tabular-nums;">{s.nr}</span>
              <div>
                <h3 style="font-size:1.125rem; font-weight:800; color:#292524; margin:0 0 0.5rem;">{s.title}</h3>
                <p style="color:#78716c; font-size:0.9375rem; line-height:1.65; margin:0;">{s.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DemoCTA headline="Haben Sie ein Projekt? Wir freuen uns drauf." body="Rufen Sie an oder schreiben Sie uns – wir melden uns innerhalb von 24 Stunden." buttonText="Jetzt Kontakt aufnehmen" bg="#292524" color="white" buttonBg="#b45309" buttonColor="white" />

    <div style="background:#fef9f0; padding:1.25rem 1.5rem; border-top:2px solid #292524;">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.8125rem; color:#78716c; margin:0;"><strong style="color:#292524;">Geeignet für:</strong> Tischler, Elektriker, Maurer, Maler, Klempner, Bäcker – alle lokalen Handwerksbetriebe und Familienunternehmen.</p>
      </div>
    </div>
  </div>

  <DemoFooter />
</div>
</BaseLayout>
