---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
import DemoCTA from '../../components/DemoCTA.astro';
---

<BaseLayout title="Editorial & Literatur – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:Georgia,'Book Antiqua',Palatino,serif;">
  <DemoHeader showBack currentStyle="Editorial & Literatur" />

  <div style="flex:1; background:#fafaf9;">

    <!-- Nav: Minimal -->
    <nav style="background:#fafaf9; border-bottom:1px solid #e7e5e4; position:sticky; top:42px; z-index:40;">
      <div style="max-width:68rem; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:60px;">
        <span style="font-size:1rem; font-weight:400; color:#1c1917; letter-spacing:0.04em;">Westwind Verlag</span>
        <div style="display:flex; align-items:center; gap:2.5rem;" class="hidden md:flex">
          {['Bücher','Autoren','Lesungen','Kontakt'].map(l => (
            <a href="#" style="font-size:0.8125rem; color:#78716c; text-decoration:none; letter-spacing:0.04em; font-family:system-ui,sans-serif; transition:color 0.2s;" onmouseover="this.style.color='#1c1917'" onmouseout="this.style.color='#78716c'">{l}</a>
          ))}
        </div>
        <button style="background:none; border:none; cursor:pointer; color:#78716c;" class="md:hidden" aria-label="Menü">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>

    <!-- Hero: Großes Zitat / Editorial -->
    <section style="padding:6rem 1.5rem 5rem; border-bottom:1px solid #e7e5e4;">
      <div style="max-width:72rem; margin:0 auto;">
        <div style="display:grid; grid-template-columns:1fr; gap:4rem; align-items:start;" class="lg:grid-cols-[2fr_1fr]">
          <div>
            <p style="font-size:0.6875rem; color:#a8a29e; letter-spacing:0.2em; text-transform:uppercase; font-family:system-ui,sans-serif; margin:0 0 2.5rem;">Frühjahr 2026 · Neue Erscheinungen</p>
            <h1 style="font-size:clamp(2.5rem,6vw,5rem); font-weight:400; color:#1c1917; line-height:1.05; letter-spacing:-0.02em; margin:0 0 2rem;">
              Bücher, die<br />bleiben.
            </h1>
            <div style="width:4rem; height:1px; background:#ca8a04; margin-bottom:2rem;"></div>
            <p style="font-size:1.125rem; color:#57534e; line-height:1.85; max-width:52ch; margin:0 0 2.5rem;">
              Seit 1983 verlegen wir Literatur, die fragt, zweifelt und standhält. Keine Bestseller-Formeln. Nur Texte, denen man vertrauen kann.
            </p>
            <a href="#" style="font-size:0.8125rem; color:#1c1917; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; border-bottom:1px solid #ca8a04; padding-bottom:0.125rem; font-family:system-ui,sans-serif; transition:color 0.2s;" onmouseover="this.style.color='#ca8a04'" onmouseout="this.style.color='#1c1917'">Programm entdecken</a>
          </div>
          <div style="padding-top:1rem;">
            <blockquote style="margin:0; padding:2rem; background:#f5f0e8; border-left:3px solid #ca8a04;">
              <p style="font-size:1.125rem; color:#1c1917; line-height:1.75; margin:0 0 1rem; font-style:italic;">
                „Literatur ist kein Spiegel der Welt. Sie ist der Versuch, die Welt neu zu denken."
              </p>
              <cite style="font-size:0.8125rem; color:#a8a29e; font-style:normal; font-family:system-ui,sans-serif; letter-spacing:0.06em;">— Programm-Grundsatz</cite>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- Editorial: Two-column -->
    <section style="padding:5rem 1.5rem;">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.6875rem; color:#a8a29e; letter-spacing:0.2em; text-transform:uppercase; font-family:system-ui,sans-serif; margin:0 0 3rem;">Neuerscheinungen</p>
        <div style="display:grid; grid-template-columns:1fr; gap:3rem;" class="md:grid-cols-2 lg:grid-cols-3">
          {[
            { label:'Roman', title:'Die Stille zwischen uns', author:'Elena Krawitz', text:'Eine Geschichte über Schweigen, Annäherung und das, was zwischen Menschen ungesagt bleibt.' },
            { label:'Essay', title:'Über das Vergessen', author:'Jonas Mühlbauer', text:'Ein philosophischer Essay über Gedächtnis, Erinnerung und was wir bewusst loslassen.' },
            { label:'Lyrik', title:'Randnotizen', author:'Sara Voss', text:'Gedichte aus dem Alltag – präzise, leise, unvermittelt nah.' },
          ].map(b => (
            <div style="border-top:1px solid #e7e5e4; padding-top:1.5rem;">
              <span style="font-size:0.6875rem; color:#ca8a04; letter-spacing:0.14em; text-transform:uppercase; font-family:system-ui,sans-serif;">{b.label}</span>
              <h3 style="font-size:1.125rem; color:#1c1917; font-weight:400; margin:0.5rem 0 0.25rem; line-height:1.3;">{b.title}</h3>
              <p style="font-size:0.875rem; color:#a8a29e; font-family:system-ui,sans-serif; margin:0 0 1rem; font-style:italic;">{b.author}</p>
              <p style="font-size:0.9375rem; color:#57534e; line-height:1.7; margin:0 0 1.25rem;">{b.text}</p>
              <a href="#" style="font-size:0.75rem; color:#1c1917; letter-spacing:0.1em; text-transform:uppercase; text-decoration:none; border-bottom:1px solid #e7e5e4; padding-bottom:0.125rem; font-family:system-ui,sans-serif; transition:border-color 0.2s;" onmouseover="this.style.borderColor='#ca8a04'" onmouseout="this.style.borderColor='#e7e5e4'">Mehr erfahren</a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DemoCTA headline="Literatur, die etwas zu sagen hat." body="Abonnieren Sie unseren Newsletter und erhalten Sie Neuerscheinungen und Lesungsankündigungen." buttonText="Newsletter abonnieren" bg="#1c1917" color="#fafaf9" buttonBg="#ca8a04" buttonColor="#1c1917" align="left" />

    <div style="background:#fafaf9; padding:1.25rem 1.5rem; border-top:1px solid #e7e5e4;">
      <div style="max-width:72rem; margin:0 auto;">
        <p style="font-size:0.8125rem; color:#78716c; margin:0; font-family:system-ui,sans-serif;"><strong style="color:#1c1917;">Geeignet für:</strong> Verlage, Autoren, Literaturhäuser, Kulturfestivals, Buchhandlungen, Blogs und Magazine.</p>
      </div>
    </div>
  </div>

  <DemoFooter />
</div>
</BaseLayout>
