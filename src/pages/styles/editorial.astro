---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
---

<BaseLayout title="Editorial & Literatur – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; background:#faf8f4; color:#1a1510;">

  <DemoHeader showBack currentStyle="Editorial & Literatur" />

  <!-- Nav: Ultra-minimal -->
  <nav style="background:#faf8f4; border-bottom:1px solid #e8e2d8; position:sticky; top:42px; z-index:40;">
    <div style="max-width:80rem; margin:0 auto; padding:0 2rem; height:56px; display:flex; align-items:center; justify-content:space-between;">
      <span style="font-family:Georgia,'Times New Roman',serif; font-size:1rem; font-weight:400; color:#1a1510; letter-spacing:0.02em;">Mara Richter</span>
      <div style="display:flex; gap:2.25rem;" class="hidden md:flex">
        {['Bücher','Essays','Lesungen','Kontakt'].map(l => (
          <a href="#" style="font-size:0.8125rem; color:#8a857e; text-decoration:none; letter-spacing:0.05em; font-family:system-ui,sans-serif; transition:color 0.15s;" onmouseover="this.style.color='#1a1510'" onmouseout="this.style.color='#8a857e'">{l}</a>
        ))}
      </div>
      <button style="background:none; border:none; cursor:pointer; color:#8a857e;" class="md:hidden" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <main style="flex:1;">

    <!-- Hero: Großes editorial Intro -->
    <section style="padding:5rem 2rem 4rem;">
      <div style="max-width:80rem; margin:0 auto;">

        <p style="font-size:0.6875rem; color:#9b2335; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 4rem; font-family:system-ui,sans-serif;">Autorin · Berlin · seit 2018</p>

        <!-- Asymmetrisches Grid -->
        <div style="display:grid; grid-template-columns:1fr; gap:3rem;" class="lg:grid-cols-[5fr_2fr]">
          <div>
            <h1 style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(2.75rem,7.5vw,6rem); font-weight:400; color:#1a1510; line-height:1.05; letter-spacing:-0.025em; margin:0;">
              Sprache als<br />
              <em style="font-style:italic; color:#9b2335;">Zuflucht.</em>
            </h1>
          </div>
          <div style="display:flex; align-items:flex-end; padding-bottom:0.5rem;">
            <p style="font-size:0.9375rem; color:#8a857e; line-height:1.8; margin:0; font-family:system-ui,sans-serif; max-width:28ch;">
              Drei Romane. Zahlreiche Essays. Eine Stimme, die das Wesentliche sucht.
            </p>
          </div>
        </div>

        <!-- Trennlinie + Link -->
        <div style="display:flex; align-items:center; gap:2rem; margin-top:3.5rem;">
          <div style="flex:1; height:1px; background:#e8e2d8;"></div>
          <a href="#" style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:#1a1510; text-decoration:none; white-space:nowrap; letter-spacing:0.06em; border-bottom:1px solid #9b2335; padding-bottom:0.2rem; transition:color 0.15s;" onmouseover="this.style.color='#9b2335'" onmouseout="this.style.color='#1a1510'">Zur aktuellen Arbeit →</a>
        </div>
      </div>
    </section>

    <!-- Zitatbereich: Großes Pull-Quote -->
    <section style="background:#f0ece4; padding:7rem 2rem;">
      <div style="max-width:80rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:2rem;" class="lg:grid-cols-[auto_1fr]">
        <!-- Dekorativer Anführungszeichen -->
        <div style="font-family:Georgia,serif; font-size:12rem; line-height:0.75; color:#e8e2d8; user-select:none; flex-shrink:0;" aria-hidden="true">„</div>
        <div style="padding-top:2rem;">
          <blockquote style="margin:0;">
            <p style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(1.375rem,2.75vw,2.125rem); font-weight:400; color:#1a1510; line-height:1.5; font-style:italic; margin:0 0 2rem;">
              Man schreibt nicht, um verstanden zu werden.<br />Man schreibt, um zu verstehen.
            </p>
            <cite style="font-family:system-ui,sans-serif; font-size:0.75rem; color:#8a857e; letter-spacing:0.14em; text-transform:uppercase; font-style:normal; display:flex; align-items:center; gap:1rem;">
              <span style="display:block; width:2rem; height:1px; background:#9b2335; flex-shrink:0;"></span>
              Aus: »Die stille Stunde«, 2022
            </cite>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Buch-Preview: Editorial-Spreads, kein Card-Look -->
    <section style="background:#1a1510; padding:6rem 2rem;">
      <div style="max-width:80rem; margin:0 auto;">

        <p style="font-family:system-ui,sans-serif; font-size:0.6875rem; color:#9b2335; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 5rem;">Aktuelle Werke</p>

        <!-- Roman -->
        <div style="display:grid; grid-template-columns:1fr; gap:2.5rem; padding-bottom:5rem; border-bottom:1px solid rgba(255,255,255,0.07);" class="lg:grid-cols-[2fr_3fr]">
          <div>
            <p style="font-family:system-ui,sans-serif; font-size:0.6875rem; color:rgba(255,255,255,0.3); letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1.25rem;">Roman · 2024</p>
            <h2 style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(1.875rem,3.5vw,3rem); font-weight:400; color:white; line-height:1.1; margin:0 0 1rem; font-style:italic;">Das offene Fenster</h2>
            <p style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.35); letter-spacing:0.06em; margin:0 0 2.5rem;">264 Seiten · Hanser Verlag</p>
            <a href="#" style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:#9b2335; text-decoration:none; letter-spacing:0.08em; border-bottom:1px solid rgba(155,35,53,0.35); padding-bottom:0.25rem; transition:border-color 0.15s;" onmouseover="this.style.borderColor='#9b2335'" onmouseout="this.style.borderColor='rgba(155,35,53,0.35)'">Leseprobe lesen →</a>
          </div>
          <div>
            <p style="font-family:Georgia,'Times New Roman',serif; font-size:1.0625rem; color:rgba(255,255,255,0.5); line-height:1.9; margin:0 0 1.75rem; font-style:italic;">
              „Clara kehrt nach zwanzig Jahren in die Stadt ihrer Kindheit zurück. Was sie findet, ist nicht das, was sie gesucht hat – und doch genau das, was sie gebraucht hätte."
            </p>
            <p style="font-family:system-ui,sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.3); line-height:1.8; margin:0;">
              Ein stiller Roman über Erinnerung, Auslassung und die Frage, ob es so etwas wie Rückkehr wirklich gibt.
            </p>
          </div>
        </div>

        <!-- Essay-Band -->
        <div style="display:grid; grid-template-columns:1fr; gap:2.5rem; padding-top:5rem;" class="lg:grid-cols-[2fr_3fr]">
          <div>
            <p style="font-family:system-ui,sans-serif; font-size:0.6875rem; color:rgba(255,255,255,0.3); letter-spacing:0.18em; text-transform:uppercase; margin:0 0 1.25rem;">Essay-Band · 2022</p>
            <h2 style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(1.875rem,3.5vw,3rem); font-weight:400; color:white; line-height:1.1; margin:0 0 1rem; font-style:italic;">Die stille Stunde</h2>
            <p style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.35); letter-spacing:0.06em; margin:0 0 2.5rem;">192 Seiten · dtv</p>
            <a href="#" style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:#9b2335; text-decoration:none; letter-spacing:0.08em; border-bottom:1px solid rgba(155,35,53,0.35); padding-bottom:0.25rem; transition:border-color 0.15s;" onmouseover="this.style.borderColor='#9b2335'" onmouseout="this.style.borderColor='rgba(155,35,53,0.35)'">Leseprobe lesen →</a>
          </div>
          <div>
            <p style="font-family:Georgia,'Times New Roman',serif; font-size:1.0625rem; color:rgba(255,255,255,0.5); line-height:1.9; margin:0 0 1.75rem; font-style:italic;">
              „Zwölf Essays über das, was wir übersehen, wenn wir zu schnell sind. Über Langsamkeit als Haltung – nicht als Luxus."
            </p>
            <p style="font-family:system-ui,sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.3); line-height:1.8; margin:0;">
              Literarische Sachprosa, die zwischen Beobachtung und Reflexion pendelt.
            </p>
          </div>
        </div>

      </div>
    </section>

    <!-- Autorenbereich: intim -->
    <section style="padding:7rem 2rem; background:#faf8f4;">
      <div style="max-width:80rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:4rem; align-items:start;" class="lg:grid-cols-[auto_1fr]">

        <!-- Abstraktes Portait-Element statt Foto -->
        <div style="flex-shrink:0;">
          <div style="width:130px; height:160px; background:linear-gradient(160deg,#e8e2d8 0%,#cdc7bd 100%); position:relative; overflow:hidden;">
            <div style="position:absolute; inset:0; background:linear-gradient(180deg,transparent 40%,rgba(26,21,16,0.6) 100%);"></div>
            <div style="position:absolute; bottom:1.25rem; left:1.25rem; font-family:Georgia,serif; font-size:1.75rem; color:rgba(255,255,255,0.7); font-style:italic; line-height:1;">MR</div>
          </div>
        </div>

        <div>
          <p style="font-family:system-ui,sans-serif; font-size:0.6875rem; color:#9b2335; letter-spacing:0.22em; text-transform:uppercase; margin:0 0 1.5rem;">Über die Autorin</p>
          <h2 style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(1.375rem,2.5vw,1.875rem); font-weight:400; color:#1a1510; margin:0 0 1.75rem; line-height:1.25;">Mara Richter</h2>
          <p style="font-family:system-ui,sans-serif; font-size:1rem; color:#6b6560; line-height:1.9; margin:0 0 1.25rem; max-width:54ch;">
            Mara Richter, geboren 1984 in Köln, studierte Germanistik und Philosophie in Freiburg und Wien. Ihr Debüt »Vor dem Licht« erschien 2018 und wurde mit dem Aspekte-Literaturpreis ausgezeichnet. Sie lebt und schreibt in Berlin.
          </p>
          <p style="font-family:system-ui,sans-serif; font-size:1rem; color:#6b6560; line-height:1.9; margin:0 0 2.25rem; max-width:54ch;">
            Ihre Texte erscheinen regelmäßig in der ZEIT, im Merkur und im Schweizer Monat. Sie unterrichtet kreatives Schreiben an der Universität der Künste Berlin.
          </p>
          <a href="#" style="font-family:system-ui,sans-serif; font-size:0.8125rem; color:#1a1510; text-decoration:none; letter-spacing:0.06em; border-bottom:1px solid #9b2335; padding-bottom:0.25rem; display:inline-block; transition:color 0.15s;" onmouseover="this.style.color='#9b2335'" onmouseout="this.style.color='#1a1510'">Pressematerial & Kontakt →</a>
        </div>
      </div>
    </section>

    <!-- Abschluss: ruhig, offen -->
    <section style="padding:6rem 2rem 5rem; border-top:1px solid #e8e2d8;">
      <div style="max-width:80rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:3rem; align-items:end;" class="lg:grid-cols-[3fr_1fr]">
        <p style="font-family:Georgia,'Times New Roman',serif; font-size:clamp(1.25rem,2.5vw,1.875rem); font-weight:400; color:#1a1510; line-height:1.55; margin:0; max-width:52ch;">
          Lesungen, Kooperationen und Verlagsanfragen – gerne per E-Mail. Alle anderen Nachrichten ebenfalls willkommen.
        </p>
        <div style="text-align:right;">
          <a href="#" style="font-family:system-ui,sans-serif; font-size:0.875rem; color:#1a1510; text-decoration:none; border-bottom:1px solid #9b2335; padding-bottom:0.25rem; display:inline-block; letter-spacing:0.04em; transition:color 0.15s;" onmouseover="this.style.color='#9b2335'" onmouseout="this.style.color='#1a1510'">post@mararichter.de →</a>
        </div>
      </div>
    </section>

    <!-- Geeignet für -->
    <section style="padding:1.75rem 2rem; background:#f0ece4; border-top:1px solid #e8e2d8;">
      <div style="max-width:80rem; margin:0 auto;">
        <p style="font-family:system-ui,sans-serif; font-size:0.875rem; color:#8a857e; margin:0; line-height:1.6;">
          <strong style="color:#1a1510; font-weight:600;">Geeignet für:</strong>
          Autorinnen und Autoren, Verlage, Literaturmagazine, Kulturinstitutionen, Buchhandlungen, Journalisten und kreative Selbstständige mit persönlicher Marke.
        </p>
      </div>
    </section>

  </main>

  <DemoFooter />
</div>
</BaseLayout>
