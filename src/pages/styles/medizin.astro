---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
import DemoCTA from '../../components/DemoCTA.astro';
---

<BaseLayout title="Medizin & Vertrauen – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif;">
  <DemoHeader showBack currentStyle="Medizin & Vertrauen" />

  <div style="flex:1; background:white;">

    <!-- Nav -->
    <nav style="background:white; border-bottom:1px solid #e0f2fe; position:sticky; top:42px; z-index:40;">
      <div style="max-width:68rem; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; height:64px;">
        <div style="display:flex; align-items:center; gap:0.625rem;">
          <div style="width:8px; height:8px; background:#0e7490; border-radius:50%;"></div>
          <div>
            <span style="font-size:0.9375rem; font-weight:600; color:#164e63;">Praxis Seewald</span>
            <span style="font-size:0.6875rem; color:#94a3b8; margin-left:0.375rem;">Allgemeinmedizin</span>
          </div>
        </div>
        <div style="display:flex; align-items:center; gap:1.75rem;" class="hidden md:flex">
          {['Leistungen','Team','Sprechzeiten','Kontakt'].map(l => (
            <a href="#" style="font-size:0.875rem; color:#64748b; text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='#0e7490'" onmouseout="this.style.color='#64748b'">{l}</a>
          ))}
          <a href="#" style="background:#0e7490; color:white; font-size:0.8125rem; font-weight:600; padding:0.5rem 1.25rem; text-decoration:none;">Online-Termin</a>
        </div>
        <button style="background:none; border:none; cursor:pointer; color:#64748b;" class="md:hidden" aria-label="Menü">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </nav>

    <!-- Hero: Centered, calm -->
    <section style="background:linear-gradient(180deg,#f0fdfa 0%,white 100%); padding:6rem 1.5rem; text-align:center;">
      <div style="max-width:50rem; margin:0 auto;">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; background:#e0f2fe; padding:0.375rem 1rem; margin-bottom:2rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#0e7490" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span style="font-size:0.75rem; font-weight:600; color:#0e7490; letter-spacing:0.08em;">Kassenarzt · Privatpatient · Hausbesuche</span>
        </div>
        <h1 style="font-size:clamp(2rem,5vw,3.25rem); font-weight:300; color:#164e63; line-height:1.3; letter-spacing:-0.01em; margin:0 0 1.5rem;">
          Ihre Gesundheit.<br />
          <strong style="font-weight:700;">In guten Händen.</strong>
        </h1>
        <p style="color:#64748b; font-size:1.0625rem; line-height:1.8; max-width:46ch; margin:0 auto 2.5rem;">
          Allgemeinmedizinische Versorgung mit Zeit für den Patienten – persönlich, sorgfältig und vertrauensvoll.
        </p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="#" style="background:#0e7490; color:white; font-size:0.875rem; font-weight:600; padding:0.9rem 2rem; text-decoration:none; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Online-Termin buchen</a>
          <a href="#" style="border:1px solid #b0e0e9; color:#0e7490; font-size:0.875rem; padding:0.9rem 2rem; text-decoration:none; transition:background 0.2s;" onmouseover="this.style.background='#f0fdfa'" onmouseout="this.style.background='white'">Sprechzeiten ansehen</a>
        </div>
      </div>
    </section>

    <!-- Services: Icon-Rows -->
    <section style="padding:5rem 1.5rem;">
      <div style="max-width:56rem; margin:0 auto;">
        <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:300; color:#164e63; text-align:center; margin:0 0 3.5rem;">
          Was wir für Sie tun können.
        </h2>
        <div style="display:flex; flex-direction:column; gap:1px; background:#e0f2fe;">
          {[
            { icon:'🩺', title:'Allgemeinmedizin', text:'Vorsorgeuntersuchungen, Diagnose und Behandlung aller Beschwerden.' },
            { icon:'💉', title:'Impfungen', text:'Alle empfohlenen Schutzimpfungen für Kinder und Erwachsene.' },
            { icon:'📋', title:'Chronische Erkrankungen', text:'Langzeitbetreuung und individuelle Therapiepläne.' },
            { icon:'🏠', title:'Hausbesuche', text:'Persönliche Versorgung für Patienten mit eingeschränkter Mobilität.' },
          ].map(s => (
            <div style="background:white; display:flex; align-items:flex-start; gap:1.5rem; padding:1.75rem 2rem;">
              <span style="font-size:1.75rem; flex-shrink:0; margin-top:0.125rem;">{s.icon}</span>
              <div>
                <h3 style="font-size:1rem; font-weight:600; color:#164e63; margin:0 0 0.375rem;">{s.title}</h3>
                <p style="color:#64748b; font-size:0.9375rem; line-height:1.65; margin:0;">{s.text}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#b0e0e9" stroke-width="2" style="flex-shrink:0; margin-left:auto; margin-top:0.25rem;" class="hidden sm:block"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </div>
          ))}
        </div>
      </div>
    </section>

    <DemoCTA headline="Gesund bleiben beginnt mit dem richtigen Arzt." body="Jetzt Online-Termin buchen – schnell, unkompliziert, ohne Warteschleife." buttonText="Termin buchen" bg="#f0fdfa" color="#164e63" buttonBg="#0e7490" buttonColor="white" />

    <div style="background:white; padding:1.25rem 1.5rem; border-top:1px solid #e0f2fe;">
      <div style="max-width:68rem; margin:0 auto;">
        <p style="font-size:0.8125rem; color:#64748b; margin:0;"><strong style="color:#164e63;">Geeignet für:</strong> Arztpraxen, Zahnarztpraxen, Physiotherapeuten, Pflegedienste, Kliniken, psychologische Praxen.</p>
      </div>
    </div>
  </div>

  <DemoFooter />
</div>
</BaseLayout>
