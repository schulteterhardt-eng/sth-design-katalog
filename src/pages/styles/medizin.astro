---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemoHeader from '../../components/DemoHeader.astro';
import DemoFooter from '../../components/DemoFooter.astro';
---

<BaseLayout title="Medizin & Vertrauen – STH Design-Katalog">
<div style="display:flex; flex-direction:column; min-height:100vh; font-family:system-ui,-apple-system,sans-serif; background:#ffffff;">

  <DemoHeader showBack currentStyle="Medizin & Vertrauen" />

  <!-- Nav -->
  <nav style="background:white; border-bottom:1px solid #e2e8f0; position:sticky; top:42px; z-index:40;">
    <div style="max-width:68rem; margin:0 auto; padding:0 1.5rem; height:64px; display:flex; align-items:center; justify-content:space-between;">
      <div>
        <span style="font-size:1rem; font-weight:700; color:#0d9488; letter-spacing:-0.01em;">Praxis</span>
        <span style="font-size:1rem; font-weight:400; color:#334155; margin-left:0.375rem;">Dr. Morgenroth</span>
      </div>
      <div style="display:flex; align-items:center; gap:2rem;" class="hidden md:flex">
        {['Leistungen','Team','Patienten','Kontakt'].map(l => (
          <a href="#" style="font-size:0.875rem; color:#64748b; text-decoration:none; transition:color 0.15s;" onmouseover="this.style.color='#0d9488'" onmouseout="this.style.color='#64748b'">{l}</a>
        ))}
        <a href="#" style="background:#0d9488; color:white; font-size:0.8125rem; font-weight:600; padding:0.5rem 1.25rem; border-radius:6px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='#0f766e'" onmouseout="this.style.background='#0d9488'">Termin buchen</a>
      </div>
      <button style="background:none; border:none; cursor:pointer; color:#64748b;" class="md:hidden" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>

  <main style="flex:1;">

    <!-- Hero -->
    <section style="background:linear-gradient(160deg,#f0fdfa 0%,#ecfeff 55%,#f0f9ff 100%); padding:5rem 1.5rem 4rem;">
      <div style="max-width:68rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:3rem; align-items:start;" class="lg:grid-cols-[3fr_2fr]">

        <!-- Text -->
        <div>
          <div style="display:inline-flex; align-items:center; gap:0.5rem; background:white; border:1px solid #b2f5ea; border-radius:100px; padding:0.375rem 1rem; margin-bottom:2rem;">
            <div style="width:7px; height:7px; background:#0d9488; border-radius:50%;"></div>
            <span style="font-size:0.75rem; font-weight:600; color:#0f766e; letter-spacing:0.06em;">Allgemeinmedizin · Duisburg-Mitte</span>
          </div>
          <h1 style="font-size:clamp(2rem,4.5vw,3.25rem); font-weight:700; color:#0f172a; line-height:1.2; letter-spacing:-0.02em; margin:0 0 1.375rem;">
            Ihre Gesundheit<br />in guten Händen.
          </h1>
          <p style="font-size:1.0625rem; color:#475569; line-height:1.8; max-width:46ch; margin:0 0 2.5rem;">
            Wir nehmen uns Zeit für Sie – für eine sorgfältige Untersuchung, verständliche Erklärungen und eine Betreuung, bei der Sie im Mittelpunkt stehen.
          </p>
          <div style="display:flex; flex-wrap:wrap; gap:0.875rem; align-items:center;">
            <a href="#" style="background:#0d9488; color:white; font-size:0.9375rem; font-weight:600; padding:0.875rem 1.875rem; border-radius:8px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='#0f766e'" onmouseout="this.style.background='#0d9488'">Termin vereinbaren</a>
            <a href="#" style="color:#0d9488; font-size:0.9375rem; font-weight:500; text-decoration:none; display:flex; align-items:center; gap:0.375rem; transition:color 0.15s;" onmouseover="this.style.color='#0f766e'" onmouseout="this.style.color='#0d9488'">
              Leistungen ansehen
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Rechte Spalte: Foto + Öffnungszeiten -->
        <div style="display:flex; flex-direction:column; gap:1.25rem;">

          <!-- Praxis-Foto -->
          <div style="border-radius:16px; overflow:hidden; box-shadow:0 4px 20px rgba(13,148,136,0.1);">
            <img
              src="/Medizin/cottonbro.jpeg"
              alt="Zahnarztpraxis Dr. Morgenroth"
              style="width:100%; height:200px; object-fit:cover; object-position:center; display:block;"
            />
          </div>

          <!-- Öffnungszeiten-Box -->
          <div style="background:white; border:1px solid #ccfbf1; border-radius:16px; padding:2rem; box-shadow:0 4px 24px rgba(13,148,136,0.07);">
            <p style="font-size:0.6875rem; font-weight:700; color:#0d9488; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 1.25rem;">Öffnungszeiten <span style="font-weight:400; color:#94a3b8; text-transform:none; letter-spacing:0;">(Beispiel)</span></p>
            {[
              { tag:'Mo, Di, Do', zeit:'08:00 – 13:00 · 14:30 – 18:00' },
              { tag:'Mittwoch',   zeit:'08:00 – 13:00' },
              { tag:'Freitag',    zeit:'08:00 – 13:00 · 14:00 – 16:00' },
            ].map((z, i) => (
              <div style={`display:flex; justify-content:space-between; padding:0.625rem 0; ${i < 2 ? 'border-bottom:1px solid #f1f5f9;' : ''}`}>
                <span style="font-size:0.875rem; font-weight:600; color:#1e293b;">{z.tag}</span>
                <span style="font-size:0.8125rem; color:#64748b;">{z.zeit}</span>
              </div>
            ))}
            <div style="margin-top:1.25rem; padding:0.875rem; background:#f0fdfa; border-radius:8px; display:flex; align-items:center; gap:0.625rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#0d9488" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span style="font-size:0.9375rem; font-weight:700; color:#0f172a;">0203 · 123 456 <span style="font-size:0.75rem; font-weight:400; color:#94a3b8;">(Beispielnummer)</span></span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Behandlungsschwerpunkte -->
    <section style="background:white; padding:5rem 1.5rem;">
      <div style="max-width:68rem; margin:0 auto;">
        <p style="font-size:0.75rem; font-weight:600; color:#0d9488; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 0.625rem;">Behandlungsschwerpunkte</p>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:700; color:#0f172a; margin:0 0 0.75rem; letter-spacing:-0.02em;">Was wir für Sie tun.</h2>
        <p style="font-size:1rem; color:#94a3b8; margin:0 0 3rem; max-width:48ch; line-height:1.65;">Ein breites Spektrum medizinischer Versorgung – persönlich und übersichtlich.</p>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.25rem;">
          {[
            {
              path:'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              titel:'Vorsorge & Check-up',
              text:'Regelmäßige Gesundheitschecks und Früherkennungsuntersuchungen für alle Altersgruppen.',
            },
            {
              path:'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
              titel:'Chronische Erkrankungen',
              text:'Langfristige Begleitung bei Diabetes, Bluthochdruck, Schilddrüsenerkrankungen und mehr.',
            },
            {
              path:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              titel:'Labordiagnostik',
              text:'Blutbild, Stoffwechselwerte und weitere Laboranalysen – schnell und aussagekräftig.',
            },
            {
              path:'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
              titel:'Familienmedizin',
              text:'Versorgung für Kinder, Erwachsene und Senioren – die ganze Familie an einem Ort.',
            },
            {
              path:'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z',
              titel:'Schlaf & Erschöpfung',
              text:'Ursachensuche und Begleitung bei Schlafproblemen, anhaltender Müdigkeit und Erschöpfungszuständen.',
            },
            {
              path:'M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z',
              titel:'Atteste & Bescheinigungen',
              text:'Arbeitsunfähigkeitsbescheinigungen, Überweisungen und weitere medizinische Dokumente.',
            },
          ].map(s => (
            <div
              style="background:#fafcff; border:1px solid #e2e8f0; border-radius:12px; padding:1.75rem; transition:border-color 0.2s,box-shadow 0.2s;"
              onmouseover="this.style.borderColor='#99f6e4';this.style.boxShadow='0 4px 16px rgba(13,148,136,0.08)'"
              onmouseout="this.style.borderColor='#e2e8f0';this.style.boxShadow='none'"
            >
              <div style="width:42px; height:42px; background:#f0fdfa; border:1.5px solid #99f6e4; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:1.125rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#0d9488" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.path}/>
                </svg>
              </div>
              <h3 style="font-size:0.9375rem; font-weight:700; color:#0f172a; margin:0 0 0.5rem;">{s.titel}</h3>
              <p style="font-size:0.875rem; color:#64748b; line-height:1.7; margin:0;">{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Vertrauen & Betreuung -->
    <section style="background:linear-gradient(160deg,#f0fdfa,#ecfeff 70%,#f0f9ff); padding:5rem 1.5rem;">
      <div style="max-width:68rem; margin:0 auto;">
        <p style="font-size:0.75rem; font-weight:600; color:#0d9488; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 0.625rem;">Vertrauen & Betreuung</p>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:700; color:#0f172a; margin:0 0 3rem; letter-spacing:-0.02em;">Medizin mit Menschlichkeit.</h2>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.5rem;">
          {[
            {
              icon:'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
              titel:'Zuhören kommt zuerst',
              text:'Wir nehmen uns Zeit für Ihr Anliegen – ohne Hetze, ohne lange Warteschleifen.',
            },
            {
              icon:'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              titel:'Verständliche Sprache',
              text:'Diagnosen und Therapieoptionen werden klar erklärt, damit Sie gut informiert entscheiden können.',
            },
            {
              icon:'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              titel:'Kontinuität',
              text:'Sie sprechen immer mit denselben Ansprechpersonen – kein Neustart, keine fremden Gesichter.',
            },
          ].map(v => (
            <div style="background:white; border-radius:14px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
              <div style="width:44px; height:44px; background:#f0fdfa; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#0d9488" stroke-width="1.75">
                  <path stroke-linecap="round" stroke-linejoin="round" d={v.icon}/>
                </svg>
              </div>
              <h3 style="font-size:1rem; font-weight:700; color:#0f172a; margin:0 0 0.625rem;">{v.titel}</h3>
              <p style="font-size:0.9375rem; color:#64748b; line-height:1.7; margin:0;">{v.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Für Patientinnen und Patienten: Split mit Foto -->
    <section style="background:white; padding:5rem 1.5rem;">
      <div style="max-width:68rem; margin:0 auto; display:grid; grid-template-columns:1fr; gap:3.5rem; align-items:start;" class="lg:grid-cols-[2fr_3fr]">

        <!-- Foto -->
        <div style="border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(13,148,136,0.09);">
          <img
            src="/Medizin/shvetsa1.jpeg"
            alt="Moderne Behandlungsmethoden"
            style="width:100%; height:100%; min-height:320px; object-fit:cover; object-position:center; display:block;"
          />
        </div>

        <!-- Info-Cards -->
        <div>
          <p style="font-size:0.75rem; font-weight:600; color:#0d9488; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 0.625rem;">Für Patientinnen und Patienten</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:700; color:#0f172a; margin:0 0 2.25rem; letter-spacing:-0.02em;">Alles, was Sie wissen müssen.</h2>

          <div style="display:flex; flex-direction:column; gap:1rem;">
            {[
              {
                titel:'Erstbesuch',
                text:'Bitte bringen Sie Ihre Versichertenkarte und – wenn vorhanden – frühere Befunde oder Ihren Medikationsplan mit.',
              },
              {
                titel:'Terminvergabe',
                text:'Termine können telefonisch oder per E-Mail vereinbart werden. Bei akuten Beschwerden bemühen wir uns um kurzfristige Termine nach Verfügbarkeit.',
              },
              {
                titel:'Kostenübernahme',
                text:'Wir behandeln Patientinnen und Patienten aller gesetzlichen Krankenkassen, Privatversicherte sowie Selbstzahler.',
              },
              {
                titel:'Barrierefreiheit',
                text:'Die Praxis ist ebenerdig und barrierefrei zugänglich. Ein Fahrstuhl ist vorhanden. Parkplätze direkt vor dem Eingang.',
              },
            ].map(p => (
              <div style="border:1px solid #e2e8f0; border-radius:12px; padding:1.375rem 1.5rem; border-left:3px solid #0d9488;">
                <h3 style="font-size:0.9375rem; font-weight:700; color:#0f172a; margin:0 0 0.375rem;">{p.titel}</h3>
                <p style="font-size:0.875rem; color:#64748b; line-height:1.75; margin:0;">{p.text}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Kontakt-CTA: kasim.jpeg als Hintergrund -->
    <section style="position:relative; overflow:hidden; padding:5rem 1.5rem;">
      <img
        src="/Medizin/kasim.jpeg"
        alt=""
        aria-hidden="true"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 30%;"
      />
      <div style="position:absolute; inset:0; background:rgba(7,30,38,0.87);" aria-hidden="true"></div>

      <div style="position:relative; max-width:52rem; margin:0 auto; text-align:center;">
        <div style="display:inline-flex; align-items:center; justify-content:center; width:54px; height:54px; background:rgba(13,148,136,0.2); border-radius:50%; margin-bottom:1.75rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#5eead4" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2rem); font-weight:700; color:white; margin:0 0 1rem; letter-spacing:-0.02em;">Wir freuen uns auf Sie.</h2>
        <p style="font-size:1rem; color:rgba(255,255,255,0.55); line-height:1.75; margin:0 0 2.5rem; max-width:42ch; display:inline-block;">Vereinbaren Sie einen Termin – telefonisch oder per E-Mail. Wir melden uns zeitnah bei Ihnen.</p>
        <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
          <a href="#" style="background:#0d9488; color:white; font-size:0.9375rem; font-weight:600; padding:0.9375rem 2rem; border-radius:8px; text-decoration:none; transition:background 0.15s;" onmouseover="this.style.background='#0f766e'" onmouseout="this.style.background='#0d9488'">Termin anfragen</a>
          <a href="#"
            style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.18); color:white; font-size:0.9375rem; padding:0.9375rem 2rem; border-radius:8px; text-decoration:none; display:flex; align-items:center; gap:0.5rem; transition:background 0.15s;"
            onmouseover="this.style.background='rgba(255,255,255,0.14)'"
            onmouseout="this.style.background='rgba(255,255,255,0.08)'"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            0203 · 123 456
          </a>
        </div>
      </div>
    </section>

    <!-- Geeignet für -->
    <section style="padding:1.75rem 1.5rem; background:#f8fafc; border-top:1px solid #e2e8f0;">
      <div style="max-width:68rem; margin:0 auto;">
        <p style="font-size:0.875rem; color:#94a3b8; margin:0; line-height:1.6;">
          <strong style="color:#334155; font-weight:600;">Geeignet für:</strong>
          Arzt- und Zahnarztpraxen, Physiotherapie, Psychologische Praxen, Sanitätshäuser, Pflegedienste und alle Gesundheitsdienstleister.
        </p>
      </div>
    </section>

  </main>

  <DemoFooter />
</div>
</BaseLayout>
